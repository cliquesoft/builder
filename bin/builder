# - http://forum.tinycorelinux.net/index.php?topic=18682.0
# - Call this script from inside the directory containing the source code
# - The types of packages produced:
# 	bin	binaries
# 	dev	development
# 	doc	documentation
#	drv	drivers
#	gir	GObject
# 	lib	libraries
# 	loc	locales
#	src	source
# - List 'cmake' options https://stackoverflow.com/questions/16851084/how-to-list-all-cmake-build-options-and-their-default-values




# DEFAULT VARIABLE DEFINITIONS

export DEBUG=0							# whether or not to show debug output during processing

export DIR_CONF='/etc/builder'					# the location of the configuration for this script		NOTE: this can't be changed in the 'config' file since we have to use this value to find the file itself!
export DIR_DUMP='/tmp/staging'					# the staging location that will be the target to dump compiled programs into for making the various packages
export DIR_INST=''						# the directory where the package contents will reside in the running system; blank=root directory
export DIR_PROF='/var/cache/builder'				# the directory storing all of the builder profiles		NOTE: the NAME value gets appended to this
export DIR_REPO='/tmp/repo'					# the location that the packaged software will be stored and source code is found (when using '-C dir') - the local software repository
export DIR_TEMP='/tmp/builder'					# the temporary location to store any information and files needed by this script

export DEP_MAKE_ALL='compiletc squashfs_tools rsync find_utils'	# compile-time deps list for all projects (e.g. compiletc, mksquashfs-tools, ...)

export EXT_BLDR='.${TYPE}.all.bldr'				# [tgz file] package builder profile
export EXT_CODE='.${TYPE}.all.code'				# [tgz file] package source code
export EXT_DEPS='.${TYPE}.${ARCH}.deps'				# [text file] package dependency list
export EXT_HASH='.${TYPE}.${ARCH}.hash'				# [text file] package validation hash
export EXT_INFO='.${TYPE}.${ARCH}.info'				# [text file] package information
export EXT_LIST='.${TYPE}.${ARCH}.list'				# [text file] package manifest list
export EXT_MAKE='.${TYPE}.${ARCH}.make'				# [text file] package make commands
export EXT_SOFT='.${TYPE}.${ARCH}.soft'				# [mksquashfs file] packaged compiled software
export EXT_BIND=''						# [text] the syntax to remove from binary package names (BIND = binary delete)

export OWN_USER='root'						# the ownership to apply to files of the package
export OWN_GROUP='staff'

export PRM_DIRS='775'						# the permissions to apply to directories of the package
export PRM_FILES='664'						# the permissions to apply to all files of the package
export PRM_EXECS='755'						# the permissions to apply to all executables in /bin, /sbin, etc and also the libraries

export URL_INFO='http://repo.cliquesoft.org/vanilla/1.1/${NAME}/${NAME}${EXT_INFO}'		# the .info file URL used to obtain the package source code (set in builder config file)
export URL_REPO='http://repo.cliquesoft.org/vanilla/1.1/${NAME}'				# the distro repo URL used to obtain the package source code and builder profiles (set in builder config file)

export SPM_ALL='$SUDO pax -i $DEP_MAKE_ALL'			# the software package manager command to install compile-time dependencies (overall)
export SPM_PACK='$SUDO pax -i $DEP_MAKE_PAK'			# the software package manager command to install compile-time dependencies (package specific)
export SPM_MAKE='$SUDO pax -S ${DIR_DUMP}/${NAME}.${TYPE} -m ${PACKAGE} ${DIR_DUMP}'		# the software package manager command to make a package from the compiled software by this script
export SPM_UNLD='$SUDO pax -u $DEP_MAKE_PAK'			# the software package manager command to unload compile-time dependencies (to keep the environment clean)

export LOG='/var/log/builder - ${NAME}.log'			# the log file for compile output (contains both stdout and stderr)
export SUDO=''							# whether or not 'sudo' should be called for all commands after the 'ownership and permissions' have been set (if they are restrictive enough to warrant it)

PATH_PKGCFG="${HOME}/.lib/pkgconfig:/Users/Public/.lib/pkgconfig:/lib/pkgconfig"  		# the default PKG_CONFIG_PATH value

# set default compile flags (which can be overwritten with DIR_CONF or individual DIR_PROF configs)
# NOTE: additional flags can also be set in this variable as well (e.g. LC_CTYPE, QT_IM_MODULE, GTK_IM_MODULE, ...)
FLAG_A32="export CFLAGS='-march=armv6zk -mtune=arm1176jzf-s -mfpu=vfp -Os -pipe'
	export CXXFLAGS='-march=armv6zk -mtune=arm1176jzf-s -mfpu=vfp -Os -pipe'
	export LDFLAGS='-Wl,-O1'
	export PKG_CONFIG_PATH='\${PATH_PKGCFG}'"		# ARM 32bit
FLAG_A64="export CFLAGS='-march=armv8-a+crc -mtune=cortex-a53 -Os -pipe'
	export CXXFLAGS='-march=armv8-a+crc -mtune=cortex-a53 -Os -pipe'
	export LDFLAGS='-Wl,-O1'
	export PKG_CONFIG_PATH='\${PATH_PKGCFG}'"		# ARM 64bit
FLAG_I32="export CFLAGS='-march=i486 -mtune=i686 -Os -pipe'
	export CXXFLAGS='-march=i486 -mtune=i686 -Os -pipe'
	export LDFLAGS='-Wl,-O1'
	export PKG_CONFIG_PATH='\${PATH_PKGCFG}'"		# Intel/AMD 32bit
FLAG_I64="export CFLAGS='-mtune=generic -Os -pipe'
	export CXXFLAGS='-mtune=generic -Os -pipe'
	export LDFLAGS='-Wl,-O1'
	export PKG_CONFIG_PATH='\${PATH_PKGCFG}'"		# Intel/AMD 64bit
FLAG_M32=""							# MIPS 32bit
FLAG_M64=""							# MIPS 64bit
FLAG_P32=""							# PowerPC 32bit
FLAG_P64=""							# PowerPC 64bit
FLAG_R32="export CFLAGS='-march=armv6zk -mtune=arm1176jzf-s -mfpu=vfp -Os -pipe'
	export CXXFLAGS='-march=armv6zk -mtune=arm1176jzf-s -mfpu=vfp -Os -pipe'
	export LDFLAGS='-Wl,-O1'
	export PKG_CONFIG_PATH='\${PATH_PKGCFG}'"		# RPi 32bit
FLAG_R64="export CFLAGS='-march=armv8-a+crc -mtune=cortex-a53 -Os -pipe'
	export CXXFLAGS='-march=armv8-a+crc -mtune=cortex-a53 -Os -pipe'
	export LDFLAGS='-Wl,-O1'
	export PKG_CONFIG_PATH='\${PATH_PKGCFG}'"		# RPi 64bit
FLAG_V32=""							# RISC-V 32bit
FLAG_V64=""							# RISC-V 64bit




# -------------------- DO **NOT** EDIT BELOW THIS LINE --------------------



								# NOTE: This sets defaults on single-pass runs, but also resets the values with multi-pass.
# [system]								Also some variables below are exported so the 'pre' and 'post' scripts can access them.
THIS="$0"							# stores this script for multi-pass calls
CPU='a32,a64,i32,i64,m32,m64,p32,p64,r32,r64,v32,v64'		# the CPU architectures that you wish to compile for (comma separated): ARM 32/64bit, Intel/AMD 32/64bit, RPi 32/64big
CWDL="$(pwd)"							# stores the current working directory location
EXPORTS=''							# the exported compile flags based on the desired CPU architecture
PACKAGE=''
export TYPE='bin'						# the type of package being made (e.g. bin, dev, doc, ...)	NOTE: the -c action uses this default value
TEMP=''								# stores a temporary value

# [names]
export NAME=''							# the name of the package being compiled
DIRECTORY=''							# the location to process

# [actions]
BUILD=''							# if we need to build a software package
INSTALL=''							# indicates we need to install the builder profile
COMPILE=''							# indicates that NO packaging should take place, only a software compile
CREATE=''							# create a builder profile
REPACK=''							# indicates that we just need to repack the software since something in the 'include' directories changed
TEMPLATE=''							# creates a blank builder profile template and exit
UNINSTALL=''							# indicates we need to uninstall the builder profile

# [options]
export ARCH=''							# the current CPU architecture being compiled (e.g. i32, i64, ...)
DIRS=''								# indicates we need to package using directory names instead of just a directory named NAME
INFOFILE=''							# stores the info file to download/use to obtain the software
export PASS=''							# the number of passes to make during compile (blank disables)
PATCH='TRUE'							# indicates we need to apply patches to the source code
SKIP='TRUE'							# indicates we need to skip packaging until the final pass (blank doesn't wait)
SINGLE=''							# indicates all files need to be placed in a single package
TRIM=''								# any part of the name to remove when building the package
METHOD=''							# the method of compile being performed (e.g. autogen, bootstrap, ...)
SOURCE=''							# indicates the location to obtain the source code from
UNLOAD=''							# indicates we need to unload the packages afterwards - regardless of success or failure

# [config]
export CHECK=0							# indicates that the 'make check' step is requested to be made during compile
export CLEAN=0							# indicates that the 'make clean' step is necessary (mostly for multi-run compiles)		NOTE: passing a '2' value performs a distclean
export CONF=0							# indicates that the 'configure' step needs to be made during compile
export PROP=0							# indicates that the 'make mrproper' step is necessary (mostly for multi-run compiles)
export TEST=0							# indicates that the 'make test' step is requested to be made during compile
export SORT=''							# indicates we need to sort the package contents on this pass
export CODE=''							# when compiling multiple softwares with a single builder profile (e.g. alsa-lib, alsa-utils), this value uniquely identifies the package per pass (e.g. config.1 > CODE='alsa-lib'; config.2 > CODE='alsa-utils')

export GIT_REPO=''						# the online git repo that can be cloned (set in a package config file)
export URL_CODE=''						# the developer URL used to obtain the package source code (set in a package config file)

export CUSTOM=''						# used when METHOD='custom'

export DIR_BIN="${DIR_INST}/bin"				# software installation directory locations
export DIR_ETC="${DIR_INST}/etc"
export DIR_LIB="${DIR_INST}/lib"
export DIR_SBIN="${DIR_INST}/bin"
export DIR_SHARE="${DIR_INST}/share"
export DIR_VAR="${DIR_INST}/var"
export DIR_MARKERS="${DIR_INST}/${DIR_VAR}/cache/software"
export DIR_SCRIPTS="${DIR_INST}/etc/init.d"

export CFG_BIN="${DIR_INST}/bin"				# compile 'configure' directory locations
export CFG_DATA="${DIR_INST}/var/share"
export CFG_DATAROOT="${CFG_DATA}"
export CFG_DOC="${CFG_DATA}/doc/${NAME}"
export CFG_DVI="${CFG_DOC}"
export CFG_HTML="${CFG_DOC}"
export CFG_INCLUDE="${DIR_INST}/lib/include"
export CFG_INFO="${CFG_DATA}/info"
export CFG_LIB="${DIR_INST}/lib"
export CFG_LIBEXEC="${CFG_LIB}/exec"
export CFG_LOCALE="${CFG_DATA}/locale"
export CFG_LOCALSTATE="${DIR_INST}/var"
export CFG_MAN="${CFG_DATA}/man"
export CFG_OLDINCLUDE="${DIR_INST}/lib/include"
export CFG_PDF="${CFG_DOC}"
export CFG_PS="${CFG_DOC}"
export CFG_SBIN="${DIR_INST}/bin"
export CFG_SHAREDSTATE="${DIR_INST}/var"
export CFG_SYSCONFIG="${DIR_INST}/etc"
export CFG_MISC=""						# a standardized extra variable that can be used per project (e.g. mplayer codecs)	NOTE: this one will need to include the switch as well (e.g. '--codec-dir=...')

export DEP_MAKE_PAK=''						# compile-time deps list for a specific project
export DEP_EXEC_BIN=''						# run-time deps list for each package type
export DEP_EXEC_DEV=''
export DEP_EXEC_GIR=''
export DEP_EXEC_LIB=''

export FLAG_CONF=''						# the flags to pass to the 'configure' script or 'cmake'
export FLAG_INST=''						# the flags to pass to the 'make install' call
export FLAG_MAKE=''						# the flags to pass to the 'make' call




# -------------------------------------------------------------------------




# DEFINE BUILT-IN FUNCTIONS FOR EXPORT




# DEFINE BUILT-IN FUNCTIONS FOR INTERNAL USE

# Syntax: stop TYPE [EXIT]
# Exits gracefully by cleaning up the desired parts of the file system after a failed build
# TYPE		[string] the type of cleanup to perform: failed, clean (for multi-pass), proper, normal
# EXIT		[number] if the function should exit this script afterwards: 0=no, 1=yes (default)
#		[ NOTE ] if TYPE != 'failed,clean,proper' this value becomes the exit code
stop() {
	[ "$1" = 'failed' ] && echo "ERROR: This step failed to complete, check the log for details."

	[ "$1" = 'quit' ] && [ "$DEP_MAKE_PAK" ] && [ "$SPM_UNLD" ] && [ "$UNLOAD" ] && {
		echo -e "\nUnloading compile-time dependencies..." | tee -a "$LOG"
		eval "$SPM_UNLD 2>>\"$LOG\""
	}

	if [ "$1" = 'failed' ]; then
		rm -Rf "${DIR_TEMP:?}/${NAME}.pass" 2>>"$LOG"	# we just delete this file to prevent issues
		exit 1
	elif [ "$1" = 'clean' ]; then
		rm -Rf "${DIR_DUMP:?}/${NAME}/"* 2>>"$LOG"	# NOTE: the ':?' prevents the expression from evaluating to 'rm /*'
		rm -Rf "${DIR_TEMP:?}/${NAME}.pass" 2>>"$LOG"
		( [ ! "$2" ] || [ $2 -eq 1 ] ) && exit 1
	elif [ "$1" = 'proper' ]; then
		[ ! "$NAMES" ] && NAMES="$NAME"			# if the 'packaging' stage hasn't been reached yet, the only directory that would possibly exist would just be NAME
		for DIR in $NAMES; do
			rm -Rf "${DIR_TEMP:?}/${DIR}/"* 2>>"$LOG"
			rm -Rf "${DIR_TEMP:?}/${DIR}.build" 2>>"$LOG"
			rm -Rf "${DIR_TEMP:?}/${DIR}.make" 2>>"$LOG"
			rm -Rf "${DIR_TEMP:?}/${DIR}.pass" 2>>"$LOG"
			rm -Rf "${DIR_TEMP:?}/${DIR}.sort" 2>>"$LOG"

			[ -d "${DIR_DUMP:?}/${DIR}" ] && rm -Rf "${DIR_DUMP:?}/${DIR}/"* 2>>"$LOG" # since the directory might not be renamed to DIR_DUMP.bin yet
			for PACK in bin dev doc drv gir lib loc; do
				if [ -d "${DIR_DUMP:?}/${DIR}.${PACK}" ]; then
					rm -Rf "${DIR_DUMP:?}/${DIR}.${PACK}" 2>>"$LOG" || {
						echo "ERROR: This step failed to complete, check the log for details."
						exit 1
					}
				fi
			done
		done
		[ -x "${DIR_PROF}/${NAME}/cleanup" ] && "${DIR_PROF}/${NAME}/cleanup" 2>>"$LOG"	# if a cleanup script has been included, execute it as well!
		( [ ! "$2" ] || [ $2 -eq 1 ] ) && exit 0
	else							# this is the 'normal' (or any other value)
		[ ! "$2" ] && exit 0 || exit $2
	fi
}




# Syntax: pass ACTION FILE
# parses the NAME.pass file and assigns value to PASS variable
# ACTION	[string] method of operation:
#			 init - checks for multi-pass and assigns a temp value to PASS
#			 inc  - read the NAME.pass file and increment the PASS value by one
# FILE		[string] the file to check: config, params
pass() {
	[ ! -e "${DIR_TEMP}/${NAME}.pass" ] && {						# if there are no passes -OR- no passes have been made yet (e.g. this is the initial invocation), then...
		[ "$2" ] && [ -e "${DIR_PROF}/${NAME}/${2}.1" ] && {				#   if a FILE was passed -AND- the initial file exists, then...
echo 'pass() init'
			[ "$2" = 'config' ] && TEMP='INIT'					#      indicate we are doing a multi-pass
			[ "$2" = 'params' ] && TEMP="$PASS"					#      indicate we are doing a multi-pass
			PASS=1									#      set the variable to an initial value so the params.1 file can be processed
			return
		}

echo 'pass() exit'
return						# if no params.* files exist, nor does a NAME.pass, then this isn't a multi-pass profile so we can exit
	}
echo 'pass() process'
	PASS="$(cat "${DIR_TEMP}/${NAME}.pass")"
	TEMP=${PASS%|*}										#   store the total passes required
	PASS=${PASS#*|}										#   store the prior pass value
	[ "$1" = 'INC' ] && PASS=$(( PASS + 1 ))						#   increase the value by 1 if instructed to
	[ $PASS -gt $TEMP ] && stop proper							#   if we have just completed the last requred pass, then cleanup and exit
	[ "$1" = 'INC' ] && echo "$TEMP|$PASS" >"${DIR_TEMP}/${NAME}.pass"			#   if we've made it here, we still have at least one pass to perform, so update the values!
}




# Syntax: package
# (Re-)packages the compiled software
package() {
	# PRE-PACKAGE SORTING

	TEMP=''
	if [ "$SINGLE" ] && ( [ "$SORT" ] || [ ! "$PASS" ] ); then				# if we do NOT need separate packages -AND- (were instructed to sort on this pass -OR- there is only one pass), then...
		# store the package names that need to be processed (either NAME or directory names)
		[ ! "$DIRS" ] && [ ! "$TRIM" ] && NAMES="$NAME"					# if we are not packaging all the directories found in DIR_DUMP -AND- no trimming should be applied, then just store the name of the requested package
		[ ! "$DIRS" ] && [ "$TRIM" ] && {						# same as above, but with trimming any portion of the name along with the actual renaming of the directory to match
			NAMES="$(echo "$NAME" | sed "s/${TRIM}//")"
			mv "$NAME" "$NAMES" 2>>"$LOG"
		}
		[ "$DIRS" ] && NAMES="$(ls -1 "$DIR_DUMP")"					# otherwise, we are so store all the names of the directories before we create the .bin, .dev, .drv, etc related directories

		for DIR in $NAMES; do
			# strip the debug symbols from the just-compiled software		  https://superuser.com/questions/236601/how-do-i-execute-multiple-commands-when-using-find
			find . -type f -executable \( -not -name \*.la -a -not -name \*.a \) -exec /bin/sh -c 'file -b --mime-type {} | grep -q application && strip --strip-unneeded {}' \;
		done

		[ ! -d "${DIR}.all" ] && mkdir "${DIR}.all" 2>>"$LOG"				# create a directory for all the files of a single package
		cp -dpR "${DIR}/*" "${DIR}.all" 2>>"$LOG"					# copy all the compiled software into that directory
		TEMP='all'									# store the directory to all files in a single package
	elif [ ! "$SINGLE" ] && ( [ "$SORT" ] || [ ! "$PASS" ] ); then				# if we need separate packages -AND- (were instructed to sort on this pass -OR- there is only one pass), then...
		cd "${DIR_DUMP}" || {								# change into the temp packaging directory
			echo "Calling: cd \"$DIR_DUMP\"" >>"$LOG"
			echo "ERROR: The staging location directory (DIR_DUMP) could not be entered." >>"$LOG"
			stop failed
		}

		# generate the sort script for the 'find' calls below
		echo '#!/bin/sh' >"${DIR_TEMP}/${NAME}.sort"
		echo 'TEMP="${2#*/}"' >>"${DIR_TEMP}/${NAME}.sort"				# strip the first directory (source) of the path from the variable value
		echo "cd \"$NAME\"" >>"${DIR_TEMP}/${NAME}.sort"				# cd into the parent directory of the source so it does not get copied as well
		echo 'rsync -a -R --devices --specials --remove-source-files "${TEMP}" "../$1"' >>"${DIR_TEMP}/${NAME}.sort"
		chmod 775 "${DIR_TEMP}/${NAME}.sort"

		# store the package names that need to be processed (either NAME or directory names)
		[ ! "$DIRS" ] && [ ! "$TRIM" ] && NAMES="$NAME"					# if we are not packaging all the directories found in DIR_DUMP -AND- no trimming should be applied, then just store the name of the requested package
		[ ! "$DIRS" ] && [ "$TRIM" ] && {						# same as above, but with trimming any portion of the name along with the actual renaming of the directory to match
			NAMES="$(echo "$NAME" | sed "s/${TRIM}//")"
			mv "$NAME" "$NAMES" 2>>"$LOG"
		}
		[ "$DIRS" ] && NAMES="$(ls -1 "$DIR_DUMP")"					# otherwise, we are so store all the names of the directories before we create the .bin, .dev, .drv, etc related directories

		echo -e "\nSeparating into various packages..." | tee -a "$LOG"
		for DIR in $NAMES; do
			[ $DEBUG -gt 0 ] && echo "   DEBUG (Processing): \"$DIR\"" | tee -a "$LOG"

			# strip the debug symbols from the just-compiled software		  https://superuser.com/questions/236601/how-do-i-execute-multiple-commands-when-using-find
			find . -type f -executable \( -not -name \*.la -a -not -name \*.a \) -exec /bin/sh -c 'file -b --mime-type {} | grep -q application && strip --strip-unneeded {}' \;

			# create all the directories to split the package contents into
			[ ! -d "${DIR}.dev" ] && mkdir "${DIR}.dev" 2>>"$LOG"
			[ ! -d "${DIR}.doc" ] && mkdir "${DIR}.doc" 2>>"$LOG"
			[ ! -d "${DIR}.drv" ] && mkdir "${DIR}.drv" 2>>"$LOG"
			[ ! -d "${DIR}.gir" ] && mkdir "${DIR}.gir" 2>>"$LOG"
			[ ! -d "${DIR}.lib" ] && mkdir "${DIR}.lib" 2>>"$LOG"
			[ ! -d "${DIR}.loc" ] && mkdir "${DIR}.loc" 2>>"$LOG"

			# split the package contents into bin, doc, dev, lib, ...
			# https://unix.stackexchange.com/questions/154818/how-to-integrate-mv-command-after-find-command
			# https://superuser.com/questions/596876/how-to-find-a-file-and-move-it-into-the-directory-it-was-found-in
			# https://unix.stackexchange.com/questions/46322/how-can-i-recursively-delete-empty-directories-in-my-home-directory
			# https://superuser.com/questions/236601/how-do-i-execute-multiple-commands-when-using-find
			find "${DIR}${CFG_DOC}" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.doc\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_HTML}" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.doc\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_INFO}" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.doc\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_MAN}" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.doc\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_DATA}/gtk-doc" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.doc\" '{}'" \; 2>/dev/null
			find "$DIR" -not -type d \( -name \*.c -o -name \*.c++ -o -name \*.h -o -name \*.hh -o -name \*.hpp -o -name \*.hxx -o -name \*.h++ -o -name \*.pc -o -name \*.la -o -name \*.a -o -name \*.m4 -o -name \*.vapi \) -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.dev\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_LIB}/cmake" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.dev\" '{}'" \; 2>/dev/null		# NOTE: this was moved below the 'doc' since some packages (xslt) have html documentation ending in .c that doesn't need to go in the 'dev' package
			find "$DIR" -not -type d -name Makefile.\* -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.dev\" '{}'" \; 2>/dev/null
			find "$DIR" -type f -name \*.ko.gz -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.drv\" '{}'" \; 2>/dev/null
			find "$DIR" -type f \( -name \*.typelib -o -name \*.gir \) -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.gir\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_LIB}/" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.lib\" '{}'" \; 2>/dev/null
			find "${DIR}${CFG_LIB}64/" -not -type d -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.lib\" '{}'" \; 2>/dev/null
			find "$DIR" -type f -name \*.mo -exec /bin/sh -c "\"${DIR_TEMP}/${NAME}.sort\" \"${DIR}.loc\" '{}'" \; 2>/dev/null

			# get rid of all empty directories from the 'bin' package
			find "$DIR" -type d -empty -delete 2>/dev/null

			# anything left should be binaries, so rename the directory
			[ -e "$DIR" ] && mv "$DIR" "${DIR}.bin"					# adjust the name so it can be included in the 'for' loop below		NOTE: test first incase the package only contains libs (which will erase this directory on the line above)
		done

		TEMP='bin dev doc drv gir lib loc'						# store all the directories the files were separated into
	fi

	# NOTE: we should only apply ownership and permissions on the final pass!!!
	#	do NOT overwrite the TEMP value!!!
	if [ ! "$PASS" ] || [ $PASS -eq $(cat "${DIR_TEMP}/${NAME}.pass" | sed 's/|.*//') ]; then						# if '-p' wasn't passed -OR- it was -and- we are on the last pass, then...
		echo -e "\nApplying ownership and permissions..." | tee -a "$LOG"		# NOTE: this has to come below the 'post' script incase that is what handles the 'install' portion when METHOD=custom (e.g. FXwm)
		for DIR in $NAMES; do
			[ $DEBUG -gt 0 ] && echo "   DEBUG (Processing): \"$DIR\"" | tee -a "$LOG"

			for PACK in $TEMP; do
				[ $DEBUG -gt 0 ] && echo -n "      DEBUG (Iterating): \"$PACK\"" | tee -a "$LOG"
				[ ! -d "${DIR_DUMP}/${DIR}.${PACK}" ] && {			# if a directory is missing then there's no reason to process something that doesn't exist!
					[ $DEBUG -gt 0 ] && echo " [skipped]" | tee -a "$LOG"
					continue
				}
				[ $DEBUG -gt 0 ] && echo " [processing]" | tee -a "$LOG"

				cd "${DIR_DUMP}/${DIR}.${PACK}" 2>>"$LOG" || {			# change into the temp packaging directory
					echo "Calling: cd \"${DIR_DUMP}/${DIR}.${PACK}\"" >>"$LOG"
					echo "ERROR: The staging location directory (DIR_DUMP) could not be entered." >>"$LOG"
					stop failed
				}
				find . \( -type f -exec chmod $PRM_FILES {} \; \) , \( -type d -exec chmod $PRM_DIRS {} \; \)			# update the permissions of all the package contents	https://stackoverflow.com/questions/3740152/how-do-i-set-chmod-for-a-folder-and-all-of-its-subfolders-and-files-in-linux-ubu
				[ "$DIR_MARKERS" ] && find ".${DIR_MARKERS}" -exec chmod $PRM_EXECS {} \; 2>/dev/null
				find ".${DIR_SCRIPTS}" -exec chmod $PRM_EXECS {} \; 2>/dev/null
				find ".${CFG_LIB}/" \( -not -type d -a -not -name \*.a \) -exec chmod $PRM_EXECS {} \; 2>/dev/null		# update the permissions of all the libraries
				find ".${CFG_LIB}64/" \( -not -type d -a -not -name \*.a \) -exec chmod $PRM_EXECS {} \; 2>/dev/null
				find ".${CFG_LIBEXEC}/" -not -type d -exec chmod $PRM_EXECS {} \; 2>/dev/null					# update the permissions of lib executables		https://www.redhat.com/archives/rpm-list/2004-February/msg00027.html  https://unix.stackexchange.com/questions/74646/difference-between-lib-lib32-lib64-libx32-and-libexec
				chmod $PRM_EXECS bin/* sbin/* usr/bin/* usr/sbin/* usr/local/bin/* usr/local/sbin/* 2>/dev/null			# update these directory contents to be executable
				eval "$SUDO chown -hR ${OWN_USER}:${OWN_GROUP} ./* >>\"$LOG\" 2>&1"						# update the ownership of all the package contents
			done
		done

		[ $DEBUG -gt 0 ] && {
			echo -n "   DEBUG: Check the DIR_DUMP and DIR_TEMP directories and press any key... "
			read
		}
	fi




	# CREATE EACH PACKAGE
echo "skip pass|$SKIP|$PASS|"
	[ ! "$SKIP" ] && [ "$PASS" ] && [ $PASS -lt $(cat "${DIR_TEMP}/${NAME}.pass" | sed 's/|.*//') ] && {
		[ $DEBUG -gt 0 ] && echo "   DEBUG: The -F and -N were passed, but we're not on the last pass."
		return 0									# if '-F' was passed -AND- '-N' was passed -AND- we are on the last pass, then exit this function
	}

	cd "${DIR_DUMP}" 2>>"$LOG" || {								# change into the temp packaging directory
		echo "Calling: cd \"$DIR_DUMP\"" >>"$LOG"
		echo "ERROR: The staging location directory (DIR_DUMP) could not be entered." >>"$LOG"
		stop failed
	}

	[ ! "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/pre.package" ] && {				# execute any existing final script (for single-pass; multi-pass is next block)
		echo -e "\nExecuting the 'pre.package' script..." | tee -a "$LOG"
		"${DIR_PROF}/${NAME}/pre.package" 2>>"$LOG" || stop failed
	}
	[ "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/pre.package.${PASS}" ] && {
		echo -e "\nExecuting the 'pre.package' script..." | tee -a "$LOG"
		"${DIR_PROF}/${NAME}/pre.package.${PASS}" 2>>"$LOG" || stop failed
	}

	# store the package names that need to be processed (either NAME or directory names)	  NOTE: this has to be performed again incase additional directories were added/removed via a 'pre.package' script
	[ ! "$DIRS" ] && [ ! "$TRIM" ] && NAMES="$NAME"						# if we are not packaging all the directories found in DIR_DUMP -AND- no trimming should be applied, then just store the name of the requested package
	[ ! "$DIRS" ] && [ "$TRIM" ] && {							# same as above, but with trimming any portion of the name along with the actual renaming of the directory to match
		NAMES="$(echo "$NAME" | sed "s/${TRIM}//")"
		eval "$SUDO mv \"$NAME\" \"$NAMES\" 2>>\"$LOG\""
	}
	[ "$DIRS" ] && NAMES="$(ls -1 "$DIR_DUMP" | sed 's/\.[^\.]*$//' | sort -u)"		# otherwise, we are so store all the names of the directories before we create the .bin, .dev, .drv, etc related directories
	[ $DEBUG -gt 0 ] && echo "   DEBUG (NAMES): \"$NAMES\""
												# NOTE: list all contents | non-greedy sed to remove extension (e.g. .bin) | sort to remove duplicates
	echo -e "\nCreating the various packages..." | tee -a "$LOG"
	OLD_NAME="$NAME"									# store the original values (since they get overwritten below to maintain consistency in naming conventions in the config files)
	OLD_TYPE="$TYPE"
	for NAME in $NAMES; do									# NOTE: the NAME variable will contain directory names, or the actual names of the packages - depending on configuration
		[ $DEBUG -gt 0 ] && echo "   DEBUG (Processing): \"$NAME\"" | tee -a "$LOG"

		for TYPE in $TEMP; do
			[ ! -d "${NAME}.${TYPE}" ] && {						# if a 'pre/post' script created directories manually, then some may be missing so no reason to process something that doesn't exist!
				[ $DEBUG -gt 0 ] && echo "   DEBUG (Interating): \"$TYPE\" [skipped]" | tee -a "$LOG"
				continue
			}

			PACKAGE="$NAME"								# store the value to possibly append NAME_SFX below
			[ "$NAME_SFX" ] && ( [ "$TYPE" != 'bin' ] || ( [ "$TYPE" = 'bin' ] && [ "$NAME_BIN" ] ) ) && eval "PACKAGE=\"${NAME}${NAME_SFX}\""

			eval "PAK_DEPS=\"$EXT_DEPS\""						# update these values if variables were included in their name
			eval "PAK_HASH=\"$EXT_HASH\""
			eval "PAK_INFO=\"$EXT_INFO\""
			eval "PAK_LIST=\"$EXT_LIST\""
			eval "PAK_SOFT=\"$EXT_SOFT\""

			[ $DEBUG -gt 0 ] && echo "   DEBUG (Pak Info): $NAME [${TYPE}], ${PACKAGE}${PAK_SOFT}" | tee -a "$LOG"

			[ "$(ls -1 "${NAME}.${TYPE}" | head -1)" = '' ] && {			# if there are no contents for the iterated package, then no reason to execute the below segment
				[ $DEBUG -gt 0 ] && echo "   DEBUG (skipped)" | tee -a "$LOG"
				continue
			}
			echo "   ${NAME} [${TYPE}]"
			echo -e "\n\n   ----- ${NAME} ${TYPE} -----\n\n" >>"$LOG"
			[ "$SPM_MAKE" ] && { eval "$SPM_MAKE" || stop failed; }			# NOTE: we use a variable so any package manager can create a native package for their distro

			( [ "$TYPE" = 'all' ] || [ "$TYPE" = 'bin' ] ) && [ "$DEP_EXEC_BIN" ] && echo -e "${DEP_EXEC_BIN}\n" | tr ' ' '\n' >>"${DIR_REPO}/${PACKAGE}${PAK_DEPS}"
			( [ "$TYPE" = 'all' ] || [ "$TYPE" = 'dev' ] ) && [ "$DEP_EXEC_DEV" ] && echo -e "${DEP_EXEC_DEV}\n" | tr ' ' '\n' >>"${DIR_REPO}/${PACKAGE}${PAK_DEPS}"
			( [ "$TYPE" = 'all' ] || [ "$TYPE" = 'gir' ] ) && [ "$DEP_EXEC_GIR" ] && echo -e "${DEP_EXEC_GIR}\n" | tr ' ' '\n' >>"${DIR_REPO}/${PACKAGE}${PAK_DEPS}"
			( [ "$TYPE" = 'all' ] || [ "$TYPE" = 'lib' ] ) && [ "$DEP_EXEC_LIB" ] && echo -e "${DEP_EXEC_LIB}\n" | tr ' ' '\n' >>"${DIR_REPO}/${PACKAGE}${PAK_DEPS}"

			mv "${PACKAGE}${PAK_SOFT}" "${PACKAGE}${PAK_LIST}" "${PACKAGE}${PAK_HASH}" "$DIR_REPO"
		done
		echo "   Your packages are now available in: ${DIR_REPO}"			# copy the files into the repo
	done
	NAME="$OLD_NAME"									# restore the original values
	TYPE="$OLD_TYPE"
	unset OLD_NAME OLD_TYPE									# delete the variable
	eval "$SUDO chown -hR ${USER} * >>\"$LOG\" 2>&1"					# update the ownership of all the package contents to be the current user so we can delete it

	[ ! "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/post.package" ] && {				# execute any existing final script (for single-pass; multi-pass is next line)
		echo -e "\nExecuting the 'post.package' script..." | tee -a "$LOG"
		"${DIR_PROF}/${NAME}/post.package" 2>>"$LOG" || stop failed
	}
	[ "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/post.package.${PASS}" ] && {
		echo -e "\nExecuting the 'post.package' script..." | tee -a "$LOG"
		"${DIR_PROF}/${NAME}/post.package.${PASS}" 2>>"$LOG" || stop failed
	}
}










# LOAD GLOBAL CONFIGURATION

[ -e "${DIR_CONF}/config" ] && . "${DIR_CONF}/config"						# System-wide config, overwriting any default variable values set at the top
[ -e "/usr/local/${DIR_CONF}/config" ] && . "/usr/local/${DIR_CONF}/config"			# ditto as alternate location
[ -e "${HOME}/.$(echo "${DIR_CONF}" | tail -c +2)/config" ] && . "${HOME}/.$(echo "${DIR_CONF}" | tail -c +2)/config"				# ditto as personalized config file - using XSB
[ -e "${HOME}/.${DIR_CONF##*/}/config" ] && . "${HOME}/.${DIR_CONF##*/}/config"			# ditto as personalized config file - using LSB

# LOAD PROFILE CONFIGURATION

eval "NAME=\${$#}"										# store the current last passed value (which should be the NAME)
echo "@ |$@|"
if ( ! echo "$@" | grep -q '\-u ' ); then							# if we're not uninstalling a profile, then...
echo 'uninstall was NOT passed'
	TEMP=''
	pass 'init' 'config'										# check if we have a multi-pass profile
	[ ! "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/config" ] && {
echo 'reading in config file'
. "${DIR_PROF}/${NAME}/config"		# Profile config
}
	[ "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/config.${PASS}" ] && {
echo "reading in config.$PASS file"
. "${DIR_PROF}/${NAME}/config.${PASS}"						# ditto, but for multi-pass
}
	[ "$TEMP" = 'INIT' ] && { TEMP=''; PASS=''; }							# if this was an initial invocation of the multi-pass profile, then reset these variables
fi

# LOAD PARAMETER DEFAULTS

if ( ! echo "$@" | grep -q '\-u ' ); then							# if we're not uninstalling a profile, then...
echo 'uninstall was NOT passed'
	[ -e "${DIR_PROF}/${NAME}/params" ] && {
echo 'reading in params file'
. "${DIR_PROF}/${NAME}/params"				# Profile parameters (general)			  NOTE: both of these files can be processed in a multi-pass profile
}
	TEMP=''
	pass 'init' 'params'										# check if we have a multi-pass profile
	[ -e "${DIR_PROF}/${NAME}/params.${PASS}" ] && {
echo "reading in params.$PASS file"
. "${DIR_PROF}/${NAME}/params.${PASS}"		# ditto, but for multi-pass (specific)
}
	[ "$TEMP" ] && { PASS="$TEMP"; }								# if this was an initial invocation of the multi-pass profile, then restore the params PASS value
fi

echo "TYPE 1 |$TYPE|$PASS|"


# PROCESS THE PASSED SWITCHES

if [ "$1" = '' ] || [ "$1" = '--help' ]; then
	echo
	echo " This project can build and install software from source code using a tailored"
	echo " profile, with an option to package those files for a Linux distro repository."
	echo
	echo "  Usage:"
	echo "	${THIS##*/} [OPTIONS] ACTION NAME [DIRECTORY]"
	echo
	echo "  Actions:"
	echo "	-b   build software from source code: install, package"
	echo "	-c   create a builder profile"
	echo "	-d   download the builder profile (uses URL_REPO)"
	echo "	-i   install the builder profile"
	echo "	-r   only re-package software instead of building"
# VER2 - for every -C value that's filled out, this can sync the software with each of those sources with a single command
#	echo "	-s   sync source code to all configured locations"
	echo "	-t   create a profile template: all, info, profile"
	echo "	-u   uninstall the builder profile"
# VER2 - check for updates to software via git or website; also allow this to be setup via cron to automatically check
#	if the (homepage) link is not present (since it would change to a different filename), there's an update
#	echo "	-v   checks for updated versions of software"
	echo
	echo "	--help      shows this screen"
	echo "	--install   installs the ${THIS##*/} software"
	echo "	--version   shows the version of this script"
	echo
	echo "  Options:"
	echo "	-A   the CPU architecture to build:"
	echo "		${CPU},all"
	echo "	-C   obtain source code from:"
# VER2 - add a 'sync' option that uses rsync
	echo "		dev(eloper)|dir(ectory)|git(clone)|(distro)repo"
	echo "	-D   package using directories in DIR_DUMP instead of NAME value"
	echo "	-F   does NOT wait until the final pass to package files"
	echo "	-I   download the package info file and use its locations"
	echo "	-M   the compile method to use:"
	echo "		autoconf"
	echo "		autogen"
	echo "		bootstrap"
	echo "		cmake"
	echo "		custom"
	echo "		default (configure, make, make install)"
	echo "		scons"
	echo "	-N   the number of passes to make when compiling"
	echo "	-P   prevent patching from occurring"
	echo "	-R   remove a portion of NAME when packaging; can use regex anchors"
	echo "	-S   package all contents in a single package - do NOT separate"
	echo "	-T   specifies the package type: bin, dev, doc, drv, gir, lib, loc"
	echo "	-U   do not unload compilation packages afterwards"
	echo
	echo
	echo "  Build Software Steps:                             [end user/package creator]"
	echo "	1. builder -d NAME [DIRECTORY] (or download the profile manually)"
	echo "	2. builder -i NAME /location/of/builder/profile"
	echo "	3. builder -b {install|package} NAME /package/source/code/directory"
	echo "	   NOTES:"
	echo "	   - each step can be combined into one call 'builder -b ... -d -i ...'"
	echo "	   - if no profile 'params' file exists, add any desired switches"
	echo "	   - use '-b install' to compile and install the software (end user)"
	echo "	   - use '-b package' to create a distributable software package"
	echo
	echo "  Profile Creation Steps:                          [developer/package creator]"
	echo "	 1. Use (or create) a 'config' in ${DIR_CONF} (or alt dir)"
	echo "	 2. Run: builder -t info NAME"
	echo "	 3. Fill out ${DIR_TEMP}/NAME.info"
	echo "	 4. Run: builder -t profile NAME"
	echo "	 5. Fill out ${DIR_TEMP}/NAME/config"
	echo "	 6. Optionally fill out ${DIR_TEMP}/NAME/params, or delete the file"
	echo "	 7. Delete ${DIR_TEMP}/NAME/proper if the directory should NOT be"
	echo "	    cleaned after compiling"
	echo "	 8. Create any 'hook' scripts (e.g. pre.compile), or delete them"
	echo "	 9. Add appropriate files under the 'include' subdirectories"
	echo "	10. Add any desired extra files under the 'extras' directory"
	echo "	11. Add any desired patches under the 'patches' directory"
	echo "	12. cd ${DIR_TEMP}"
	echo "	13. Run: builder -c NAME"
	echo
	echo "  Profile Contents Key:"
	echo "	extras [directory]"
	echo "	  stores any files that are useful to the compiled program"
	echo "	  (e.g. apachee httpd.conf for php); useful when DIRS=TRUE"
	echo "	  NOTES:"
	echo "	  - the files here need manual placement if they will be used"
	echo "	include [directory]"
	echo "	  contains items like .desktop files, icons, install markers/scripts,"
	echo "	  service scripts, etc. (e.g. include/DIR_ETC/php/php.conf)"
	echo "	  NOTES:"
	echo "	  - do NOT rename the subdirectories (e.g. DIR_ETC)!"
	echo "	  - the files in these directories get installed automatically"
	echo "	patches [directory]"
	echo "	  list of patches to apply to the codebase; they are applied in the"
	echo "	  order of an 'ls -1' - name appropriately!"
	echo "	config [file]"
	echo "	  the compile configuration for the software"
	echo "	params [file]"
	echo "	  its presence indicates the proper switches are listed here instead"
	echo "	  of passing the parameters on the command line"
	echo "	proper [file]"
	echo "	  its presence indicates a final cleanup"
	echo
	echo "	- For flexibility there are 'hook' scripts that can be incorporated"
	echo "	  to execute at various steps of operation:"
	echo "	      pre.compile	executed right before compiling"
	echo "	      post.configure	executed after a generated config"
	echo "	      post.compile	executed after compiling"
	echo "	      pre.package	executed right before packaging"
	echo "	      post.package	executed after packaging"
	echo "	      cleanup		executed as last command before exiting"
	echo "	- For multi-pass compiles, name the files in a mannor such as:"
	echo "	      pre.compile.1, pre.compile.2, config.1, config.2, etc"
	echo "	      (also apply to the 'include' directory - include.1/DIR_ETC)"
	echo
	echo "  Notes:"
	echo "	- Unless the '-C' switch was passed, with an accompanying config file"
	echo "	  CODE value, you must start this program from within the source code"
	echo "	  directory where the 'configure', 'autogen', etc scripts reside."
	echo "	- The '-C dir' looks in DIR_REPO for source code."
	echo "	- The '-D' switch is useful for making multiple packages from"
	echo "	  a single compile (e.g. php, php-cli, php-fpm, ...)"
	echo "	- It is possible to compile multiple softwares with a single"
	echo "	  builder profile (e.g. alsa-libs, alsa-utils) - see NOTES"
	echo
	exit 0
elif [ "$1" = '--install' ]; then
	[ ! -e "${DIR_CONF}/install" ] && {
		echo "ERROR: The install script is missing to perform this action."
		echo "       If this was installed from a package, builder is already installed."
		exit 1
	}
	"${DIR_CONF}/install" || exit 1
	exit 0
elif [ "$1" = '--version' ]; then
	head -5 $0 | grep Updated | sed "s/.*\\t//;s/ .*//;s:/:.:g"
	exit 0
else
	TEMP=0
	while getopts A:b:cC:dDFiIM:N:PrR:St:T:uU OPTION; do					# NOTE: the 'A:' indicates that the '-A' switch requires a value!
		( echo $OPTION | grep -qe '[a-z]' ) && TEMP=1					# if we've reached an ACTION, then...
		if [ $TEMP -gt 0 ] && ( echo $OPTION | grep -qe '[A-Z]' ); then			# if an ACTION was already processed -AND- we've reached an OPTION, then...
			echo "ERROR: All OPTIONS must preceed the ACTION."
			exit 1
		fi

		case ${OPTION} in
			A) ( echo "${OPTARG}" | grep -qE ^"($(echo "${CPU}" | sed 's/,/|/g')|all)"$ ) || {
				echo "ERROR: An invalid value for '-A' was passed."
				exit 1
			   }
			   ARCH="$OPTARG" ;;
			b) ( echo "${OPTARG}" | grep -qE ^'(install|package)'$ ) || {
				echo "ERROR: An invalid value for '-b' was passed."
				exit 1
			   }
			   BUILD="$OPTARG" ;;
			c) CREATE='TRUE' ;;
			C) ( echo "${OPTARG}" | grep -qE ^'(dev|dir|git|repo)'$ ) || {
				echo "ERROR: An invalid value for '-C' was passed."
				exit 1
			   }
			   SOURCE="$OPTARG" ;;
			d) DOWNLOAD='TRUE' ;;
			D) DIRS='TRUE' ;;
			F) SKIP='' ;;
			i) INSTALL='TRUE' ;;
			I) INFOFILE='TRUE' ;;
			M) METHOD="$OPTARG" ;;
			N) PASS="$OPTARG" ;;
			P) PATCH='' ;;
			r) REPACK='TRUE' ;;
			R) TRIM="$OPTARG" ;;
			S) SINGLE='TRUE' ;;
			t) ( echo "${OPTARG}" | grep -qE ^'(all|info|profile)'$ ) || {
				echo "ERROR: An invalid value for '-t' was passed."
				exit 1
			   }
			   TEMPLATE="$OPTARG" ;;
			T) ( echo "${OPTARG}" | grep -qE ^'(bin|dev|doc|drv|gir|lib|loc)' ) || {
				showMsg 'failure' "ERROR: An invalid value for '-T' was passed." 'screen'
				exit 1
			   }
			   TYPE="$OPTARG" ;;
			u) UNINSTALL='TRUE' ;;
			U) UNLOAD='TRUE' ;;
			*) exit 1 ;;				# NOTE: since 'getopts' presents it own error, we don't need to do so here
		esac
	done

echo "TYPE 2 |$TYPE|"


	# TEST FOR MANDATORY VALUE(S)

	EXE_CMD="${0##*/} $@"									# store the executed command for logging below
	shift $(expr $OPTIND - 1)								# now that the ACTIONS and OPTIONS have been processed, lets process the package name(s)
	eval "TEMP=\${$#}"									# store the current last passed value to later check if a directory was passed as the last value	http://stackoverflow.com/questions/1853946/getting-the-last-argument-passed-to-a-shell-script
	if [ "$TEMP" != "$0" ] && ( echo "$TEMP" | grep -q '/' ); then				# if a DIRECTORY was passed, then...
		[ "$SOURCE" != 'dir' ] && [ ! -d "$TEMP" ] && { echo "ERROR: The passed directory does not exist (${TEMP})."; exit 1; }		#  if '-C dir' was NOT passed -AND- if it does NOT exist, then...

		DIRECTORY="$TEMP"								#   store the DIRECTORY value

		TEMP=''
		for PARAMETER in ${@}; do							#   process each remaining parameter (after the OPTIONS and ACTION have been removed)
			[ "$PARAMETER" = "$DIRECTORY" ] && break				#   if we have reached the DIRECTORY value, break out of the 'for' loop to NOT include it
			TEMP="$TEMP $PARAMETER"							#   append each parameter to the list
		done
		set -- $TEMP									#   now reset the $@ array (e.g. $1, $2, $3, etc) with the adjusted parameters list

		( echo "$DIRECTORY" | grep -q '/'$ ) && [ "$DIRECTORY" != '/' ] && DIRECTORY="${DIRECTORY%/*}"					#   if the user included a trailing '/' on the passed directory -AND- it wasn't root, then remove it
		( echo "$DIRECTORY" | grep -q ^'./' ) && DIRECTORY="$(pwd)${DIRECTORY#*.}"	# if a relative directory was passed, adjust the value to be the whole path
		( echo "$DIRECTORY" | grep -q ^'/' ) || DIRECTORY="$(pwd)/${DIRECTORY}" 
	fi
	if [ "$TEMPLATE" ]; then
		NAME='template'									# this is just so the log file doesn't get named 'builder - .log' when performing this action
	else
		eval "NAME=\${$#}"								# store the current last passed value as the package name
		( [ "$NAME" = '' ] || [ "$NAME" = "$0" ] ) && { echo "ERROR: you must provide a name before processing can begin."; exit 1; }	# if a blank value was given -OR- no value given at all (since the 'shift' command will go back to $0)
	fi
fi




# MANDATORY CHECKS BEFORE **ANY** PROCESSING

# action checking						  NOTE: we can't write to a log yet since those checks haven't occurred
TEMP=0
[ "$BUILD" ] && TEMP=$(( TEMP + 1 ))
[ "$CREATE" ] && TEMP=$(( TEMP + 1 ))
[ "$DOWNLOAD" ] && TEMP=$(( TEMP + 1 ))
[ "$INSTALL" ] && TEMP=$(( TEMP + 1 ))
[ "$REPACK" ] && TEMP=$(( TEMP + 1 ))
[ "$TEMPLATE" ] && TEMP=$(( TEMP + 1 ))
[ "$UNINSTALL" ] && TEMP=$(( TEMP + 1 ))
[ $TEMP -gt 1 ] && [ ! "$CREATE" ] && [ ! "$REPACK" ] && [ ! "$TEMPLATE" ] && [ ! "$UNINSTALL" ] && TEMP=1					# if the -d, -i, and -{b|c} were chained, that is permissible, any other chained actions are not!
[ $TEMP -gt 1 ] && { echo "ERROR: These ACTIONs can't be chained, use only one of them."; exit 1; }
[ $TEMP -eq 0 ] && { echo "ERROR: You must provide an ACTION when executing this script."; exit 1; }

# option adjustments						  NOTE: this adjusts parameters that were read in the 'params' files at the top even though a -b was not passed to make sure the below tests are not triggered
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -A') && { ARCH=''; }
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -C') && { SOURCE=''; }
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -D') && { DIRS=''; }
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -F') && { SKIP='TRUE'; }
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -M') && { METHOD=''; }
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -N') && { PASS=''; }
[ ! "$BUILD" ] && ( ! echo "$EXE_CMD" | grep -q ' -R') && { TRIM=''; }

# option checking
[ "$ARCH" ] && [ ! "$BUILD" ] && { echo "The -A option can't be used with this action."; exit 1; }
[ "$SOURCE" ] && [ ! "$BUILD" ] && { echo "The -C option can't be used with this action."; exit 1; }
[ "$DIRS" ] && [ ! "$BUILD" ] && { echo "The -D option can't be used with this action."; exit 1; }
[ ! "$SKIP" ] && [ ! "$BUILD" ] && { echo "The -F option can't be used with this action."; exit 1; }
[ "$INFOFILE" ] && [ ! "$BUILD" ] && { echo "The -I option can't be used with this action."; exit 1; }
[ "$INFOFILE" ] && [ ! "$SOURCE" ] && { echo "The -I option must be used with the -C option."; exit 1; }
[ "$METHOD" ] && [ ! "$BUILD" ] && { echo "The -M option can't be used with this action."; exit 1; }
[ "$PASS" ] && [ ! "$BUILD" ] && { echo "The -N option can't be used with this action."; exit 1; }
[ ! "$PATCH" ] && [ ! "$BUILD" ] && { echo "The -P option can't be used with this action."; exit 1; }
[ "$TRIM" ] && [ ! "$BUILD" ] && { echo "The -R option can't be used with this action."; exit 1; }
[ "$SINGLE" ] && [ ! "$BUILD" ] && { echo "The -S option can't be used with this action."; exit 1; }
[ "$UNLOAD" ] && [ ! "$BUILD" ] && { echo "The -U option can't be used with this action."; exit 1; }
[ ! "$SKIP" ] && [ ! "$PASS" ] && { echo "ERROR: The '-F' option requires a valid '-N' value."; exit 1; }
if [ "$SOURCE" != '' ]; then
	TEMP=''
	[ ! "$INFOFILE" ] && ( ( [ "$SOURCE" = 'dev' ] && [ ! "$URL_CODE" ] ) || ( [ "$SOURCE" = 'dir' ] && [ ! "$DIR_REPO" ] ) || ( [ "$SOURCE" = 'git' ] && [ ! "$GIT_REPO" ] ) || ( [ "$SOURCE" = 'repo' ] && [ ! "$URL_REPO" ] ) ) && {
		[ "$SOURCE" = 'dev' ] && TEMP='URL_CODE'
		[ "$SOURCE" = 'dir' ] && TEMP='DIR_REPO'
		[ "$SOURCE" = 'git' ] && TEMP='GIT_REPO'
		[ "$SOURCE" = 'repo' ] && TEMP='URL_REPO'

		echo "ERROR: The '-C $SOURCE' option requires a $TEMP value."
		exit
	}

	if [ "$SOURCE" = 'dir' ]; then
		[ ! "$DIRECTORY" ] && {
			echo "ERROR: The '-C dir' option requires a DIRECTORY value including the filename."
			exit
		}
		[ ! -f "$DIRECTORY" ] && {
			echo "ERROR: The '-C dir' option requires a filename appended to the DIRECTORY value."
			exit
		}
		[ "$INFOFILE" ] && {
			echo "ERROR: The '-C dir' option can't be used with the -I option."
			exit
		}
	fi
	[ "$SOURCE" = 'git' ] && [ ! "$(which git)" ] && {
		echo "ERROR: The git binary is missing and is necessary when using '-C git'."
		exit
	}
fi

# set default/uninitialized variable values			  NOTE: we have to set these here since they rely on functions above
[ ! "$ARCH" ] && ARCH='i64'
[ ! "$METHOD" ] && METHOD='default'
eval "LOG=\"$LOG\""

if [ ! "$TEMPLATE" ]; then
	eval "DIR_DUMP=\"$DIR_DUMP\""
	eval "DIR_INST=\"$DIR_INST\""
	eval "DIR_REPO=\"$DIR_REPO\""
	eval "DIR_TEMP=\"$DIR_TEMP\""

	eval "URL_CODE=\"$URL_CODE\""
	eval "URL_INFO=\"$URL_INFO\""

	# NOTE: we can't eval the EXT_ variables here since they need to be interpritted at different times
fi

[ "$ARCH" = 'a32' ] && eval "EXPORTS=\"$FLAG_A32\""
[ "$ARCH" = 'a64' ] && eval "EXPORTS=\"$FLAG_A64\""
[ "$ARCH" = 'i32' ] && eval "EXPORTS=\"$FLAG_I32\""
[ "$ARCH" = 'i64' ] && eval "EXPORTS=\"$FLAG_I64\""
[ "$ARCH" = 'm32' ] && eval "EXPORTS=\"$FLAG_M32\""
[ "$ARCH" = 'm64' ] && eval "EXPORTS=\"$FLAG_M64\""
[ "$ARCH" = 'p32' ] && eval "EXPORTS=\"$FLAG_P32\""
[ "$ARCH" = 'p64' ] && eval "EXPORTS=\"$FLAG_P64\""
[ "$ARCH" = 'r32' ] && eval "EXPORTS=\"$FLAG_R32\""
[ "$ARCH" = 'r64' ] && eval "EXPORTS=\"$FLAG_R64\""
[ "$ARCH" = 'v32' ] && eval "EXPORTS=\"$FLAG_V32\""
[ "$ARCH" = 'v64' ] && eval "EXPORTS=\"$FLAG_V64\""


# check the directories						  NOTE: we can't write to a log yet since those checks are occurring
if [ ! -d "${DIR_DUMP}/${NAME}" ]; then
	mkdir -p "${DIR_DUMP}/${NAME}" >/dev/null 2>&1 || { echo "ERROR: The staging location directory (DIR_DUMP) does not exist and could not be created."; exit 1; }
fi
touch "${DIR_DUMP}/${NAME}/writable" >/dev/null 2>&1 || { echo "ERROR: The staging location directory (DIR_DUMP) is not writable."; exit 1; }
rm "${DIR_DUMP}/${NAME}/writable" >/dev/null 2>&1

if [ ! -d "${LOG%/*}" ]; then
	mkdir -p "${LOG%/*}" >/dev/null 2>&1 || { showMsg 'failure' "The logs directory (${LOG%/*}) does not exist and could not be created." 'screen'; exit 1; }
fi
touch "${LOG%/*}/writable" >/dev/null 2>&1 || { showMsg 'failure' "The logs directory ($LOG%/*}) is not writable." 'screen'; exit 1; }
rm "${LOG%/*}/writable" >/dev/null 2>&1

if [ ! -d "${DIR_PROF}" ]; then
	mkdir -p "${DIR_PROF}" >/dev/null 2>&1 || { echo "ERROR: The profile cache directory (DIR_PROF) does not exist and could not be created."; exit 1; }
fi
touch "${DIR_PROF}/writable" >/dev/null 2>&1 || { echo "ERROR: The profile cache directory (DIR_PROF) is not writable."; exit 1; }
rm "${DIR_PROF}/writable" >/dev/null 2>&1

if [ ! -d "$DIR_REPO" ]; then
	mkdir -p "$DIR_REPO" >/dev/null 2>&1 || { echo "ERROR: The local software repository (DIR_REPO) does not exist and could not be created."; exit 1; }
fi
touch "${DIR_REPO}/writable" >/dev/null 2>&1 || { echo "ERROR: The local software repository (DIR_REPO) is not writable."; exit 1; }
rm "${DIR_REPO}/writable" >/dev/null 2>&1

if [ "$TEMPLATE" ]; then					# if we're creating a template, then just check for the temp directory (the other portion is handled below)
	if [ ! -d "${DIR_TEMP}" ]; then
		mkdir -p "${DIR_TEMP}" >/dev/null 2>&1 || { echo "ERROR: The temporary directory (DIR_TEMP) does not exist and could not be created."; exit 1; }
	fi
	touch "${DIR_TEMP}/writable" >/dev/null 2>&1 || { echo "ERROR: The temporary directory (DIR_TEMP) is not writable."; exit 1; }
	rm "${DIR_TEMP}/writable" >/dev/null 2>&1
else								# otherwise let's create the entire temp path
	if [ ! -d "${DIR_TEMP}/${NAME}" ]; then
		mkdir -p "${DIR_TEMP}/${NAME}" >/dev/null 2>&1 || { echo "ERROR: The temporary directory (DIR_TEMP) does not exist and could not be created."; exit 1; }
	fi
	touch "${DIR_TEMP}/${NAME}/writable" >/dev/null 2>&1 || { echo "ERROR: The temporary directory (DIR_TEMP) is not writable."; exit 1; }
	rm "${DIR_TEMP}/${NAME}/writable" >/dev/null 2>&1
fi




if [ ! "$PASS" ] || [ $PASS -eq 1 ]; then
	echo "---------- [ Script Execution ] ----------" >"$LOG"
	echo "           $(date +'%Y-%m-%d  %H:%M:%S')" >>"$LOG"
	echo >>"$LOG"
	echo "$EXE_CMD" >>"$LOG"
elif [ "$PASS" ]; then
	echo -e "\n\n\n\n" >>"$LOG"				# add some breaks between builds if the log already exists
	echo "------- PASS: ${PASS}  $(date +'%Y-%m-%d %H:%M:%S') -------" >>"$LOG"
fi


echo "TYPE 3 |$TYPE|"

# CHANGE DIRECTORY

if [ "$DIRECTORY" ]; then									# if DIRECTORY was passed, then...
	[ "$TEMPLATE" ] && DIR_TEMP="$DIRECTORY"						#   if we're creating a template, then we need to change this variable value so the below code works correctly
	[ "$UNINSTALL" ] && DIR_PROF="$DIRECTORY"						#   if we're uninstalling a profile, then we need to change this variable value so the below code works correctly

	[ "$CREATE" ] && { cd "${DIRECTORY}/.." >/dev/null || exit 1; }				#   if we're creating a builder profile...		NOTE: this goes one level up from the passed DIRECTORY value
	[ ! "$CREATE" ] && [ "$SOURCE" != 'dir' ] && { cd "$DIRECTORY" >/dev/null || exit 1; }	#   for any other action (that doesn't involve '-C dir'), change into the DIRECTORY
else												# otherwise it was NOT passed, so...
	[ "$DOWNLOAD" ] && cd "$DIR_PROF"							#   change into the default download location
	[ "$INSTALL" ] && cd "$DIR_PROF"							#   ditto
fi




# PROCESS THE ACTIONS

if [ "$DOWNLOAD" ]; then
	echo -n "Downloading the requested builder profile:" | tee -a "$LOG"

	eval "EXT_BLDR=\"$EXT_BLDR\""

	if [ -e "${NAME}${EXT_BLDR}" ]; then
		echo " [exists]" | tee -a "$LOG"
	else
		( eval "wget -cq \"${URL_REPO}/${NAME}${EXT_BLDR}\" -O \"./${NAME}${EXT_BLDR}\" 2>&1 | sed 's/^w/ \[failure\]\nw/' | tee -a \"$LOG\" | grep -q ^'wget'" ) && {
			eval "echo -e \"Calling: wget -cq \\\"${URL_REPO}/${NAME}${EXT_BLDR}\\\" -O \\\"./${NAME}${EXT_BLDR}\\\"\" >>\"$LOG\""
			eval "echo \"ERROR: The package builder profile download failed (${NAME}${EXT_BLDR}).\" >>\"$LOG\""
			stop failed
		}
		echo " [done]" | tee -a "$LOG"
	fi
	[ ! "$INSTALL" ] && exit 0								# if we're not also installing the profile, then we need to exit
echo "TYPE 4 |$TYPE|"
fi

# NOTE: these have to be separate 'if' statements so ONLY these two can be chained with others!

if [ "$INSTALL" ]; then
	echo -n "Installing the requested builder profile:" | tee -a "$LOG"

	[ -e "${DIR_PROF}/${NAME}" ] && {							# check that the directory name does NOT already exist in the profile listings
		echo " [failure]" | tee -a "$LOG"
		echo "ERROR: A profile with that name already exists. Either rename or delete it." >>"$LOG"
		echo "       The existing profile is: ${DIR_PROF}/${NAME}" >>"$LOG"
		stop failed
	}

	eval "EXT_BLDR=\"$EXT_BLDR\""

	[ ! -e "${NAME}${EXT_BLDR}" ] && {
		echo " [failure]" | tee -a "$LOG"
		echo "ERROR: No file exists with that name. If a prior attempt failed, then the" >>"$LOG"
		echo "       filename has probably changed." >>"$LOG"
		stop failed
	}

	if ( file -b --mime-type "${NAME}${EXT_BLDR}" | grep -q 'application/[x\-]*gzip' ); then # if the profile has been checked and does not exist, then...
		tar -xzf "${NAME}${EXT_BLDR}" -C "$DIR_PROF" 2>>"$LOG" || {
			echo " [failure]" | tee -a "$LOG"
			echo "Calling: tar -xzf \"${NAME}${EXT_BLDR}\" -C \"$DIR_PROF\"" >>"$LOG"
			echo "ERROR: The builder profile could not be installed." >>"$LOG"
			stop failed
		}
	else											# NOTE: this is a safety-net in case something is wrong with the file
		echo " [failure]" | tee -a "$LOG"
		echo "ERROR: The builder profile appears to be the wrong format." >>"$LOG"
		stop failed
	fi
	echo " [done]" | tee -a "$LOG"

	# if we're not also building or compiling, then we need to exit
	[ ! "$BUILD" ] && exit 0

#echo "CMD 1 |$EXE_CMD|"
	EXE_CMD="$(echo "$EXE_CMD" | sed 's/ -d//;s/ -i//')"	# retain the current builder call without the -i or -d parameters
#echo "CMD 2 |$EXE_CMD|"
	exec $EXE_CMD						# re-launch builder using the adjusted parameters
								# NOTE: exec will replace this invocation of the script with the above line	https://stackoverflow.com/questions/18351198/what-are-the-uses-of-the-exec-command-in-shell-scripts
#echo DBUG
#exit 0

#	# otherwise, load the profile configuraiton
#	[ ! "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/config" ] && . "${DIR_PROF}/${NAME}/config"
#	[ "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/config.${PASS}" ] && . "${DIR_PROF}/${NAME}/config.${PASS}"
#
#	# and any switch configurations
#	[ ! "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/params" ] && . "${DIR_PROF}/${NAME}/params"
#	[ "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/params.${PASS}" ] && . "${DIR_PROF}/${NAME}/params.${PASS}"
echo "TYPE 5 |$TYPE|"
fi

# NOTE: these have to be separate 'if' statements so ONLY these two can be chained with others!

if [ "$CREATE" ]; then
	[ ! -d "$NAME" ] && {
		echo "ERROR: No directory exists with that name."
		exit 1
	}
	echo "Calling: tar -czf \"${NAME}${EXT_BLDR}\"\ \"$NAME\"" >>"$LOG"
	tar -czf "${NAME}${EXT_BLDR}" "$NAME" 2>>"$LOG" || {
		echo "ERROR: The builder profile could not be created." >>"$LOG"
		exit 1
	}
	exit 0


elif [ "$REPACK" ]; then
	package
	exit 0


elif [ "$TEMPLATE" ]; then
	if [ "$TEMPLATE" = 'all' ] || [ "$TEMPLATE" = 'info' ]; then
		eval "EXT_INFO=\"$EXT_INFO\""

		echo -e "\nCreating a package .info file template..." | tee -a "$LOG"
		echo "name:		${NAME}" >"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "title:		Concise title" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "description:	Short description" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "version:	1.2.3" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "released:	YYYY.MM.DD" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "packaged:	YYYY.MM.DD" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "authors:	Name(s)" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "homepage:	https://www.company.com" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "download:	path/to/file/filename.tgz" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "git:		https://distributor.com/path/to/project" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "commit:		path/to/commit/abcd...wxyz" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "file:		path/to/file/filename.tgz" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "clone:		.git" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "repo:		http://distro.com/path/to/repo" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo -n "package:	" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		eval "echo \"example-1.2.3.${EXT_SOFT}\" >>\"${DIR_TEMP}/${NAME}${EXT_INFO}\""
		echo -n "source:		" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		eval "echo \"example-1.2.3.${EXT_CODE}\" >>\"${DIR_TEMP}/${NAME}${EXT_INFO}\""
		echo -n "builder:	" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		eval "echo \"example-1.2.3.${EXT_BLDR}\" >>\"${DIR_TEMP}/${NAME}${EXT_INFO}\""
		echo -n "compile:	" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		eval "echo \"example-1.2.3.${EXT_MAKE}\" >>\"${DIR_TEMP}/${NAME}${EXT_INFO}\""
		echo "size:		100K" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "installed:	150K" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "category:	system	# education|games|multimedia|productivity|social|system|utilities" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "interface:	gui	# cli|gui" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "toolkit:	gtk2	# none  [CLI] shell|lua|ruby|php|python|tcl|tk|...  [GUI] fltk|gtk|html|qt|wxWidgets|..." >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "rating:		g	# g|pg|pg-13|nc-17|r" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "license:	LGPLv2.1" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "document:	https://www.gnu.org/licenses/lgpl-2.1.en.html" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "maintainer:	example_maintainer_alias" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "tags:		space separated project keywords" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "overview:	This is a detailed overview for the example project" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "comments:	Any applicable comments for the package" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"
		echo "changes:	Brief list of changes between package releases" >>"${DIR_TEMP}/${NAME}${EXT_INFO}"

		echo | tee -a "$LOG"
		echo "The sample .info file has been successfully created! It can be found at:" | tee -a "$LOG"
		echo "  ${DIR_TEMP}/${NAME}.info" | tee -a "$LOG"
		echo | tee -a "$LOG"
	fi

	# NOTE: these are two separate 'if' statements on purpose

	if [ "$TEMPLATE" = 'all' ] || [ "$TEMPLATE" = 'profile' ]; then
		echo -e "\nCreating a builder profile template..." | tee -a "$LOG"

		[ -e "${DIR_TEMP}/${NAME}" ] && {
			echo "ERROR: a profile with that name already exists."
			exit 1
		}
		echo "Calling: mkdir -p \"${DIR_TEMP}/${NAME}\"" >>"$LOG"
		mkdir -p "${DIR_TEMP}/${NAME}" >>"$LOG" 2>&1 || {
			echo "ERROR: The profile directory (DIR_TEMP) does not exist or could not be created." >>"$LOG"
			stop failed
		}
		cd "${DIR_TEMP}/${NAME}" >/dev/null
		echo "Calling: mkdir -p \"${DIR_TEMP}/${NAME}\"" >>"$LOG"
		mkdir -p extras include patches >>"$LOG" 2>&1 || {
			echo "ERROR: The profile directory (DIR_TEMP) does not exist or could not be created." >>"$LOG"
			stop failed
		}
		cd "${DIR_TEMP}/${NAME}/include" >/dev/null
		echo "Calling: mkdir -p \"${DIR_TEMP}/${NAME}\"" >>"$LOG"
		mkdir -p DIR_BIN DIR_ETC DIR_LIB DIR_SBIN DIR_SHARE DIR_VAR DIR_MARKERS DIR_SCRIPTS CFG_BIN CFG_DATA CFG_DATAROOT CFG_DOC CFG_DVI CFG_HTML CFG_INCLUDE CFG_INFO CFG_LIB CFG_LIBEXEC CFG_LOCALE CFG_LOCALSTATE CFG_MAN CFG_OLDINCLUDE CFG_PDF CFG_PS CFG_SBIN CFG_SHAREDSTATE CFG_SYSCONFIG CFG_MISC >>"$LOG" 2>&1 || {
			echo "ERROR: The profile directory (DIR_TEMP) does not exist or could not be created." >>"$LOG"
			stop failed
		}
		echo "- Do NOT rename these directories!" >"README.txt"
		echo "- Place appropriate files in the appropriate directories." >>"README.txt"
		echo "- Empty directories can be deleted if desired." >>"README.txt"
		echo "- This file can be deleted." >>"README.txt"
		echo >>"README.txt"
		echo "Directory Installation Locations:" >>"README.txt"
		echo "DIR_BIN		LSB: /bin" >>"README.txt"
		echo "DIR_ETC		LSB: /etc" >>"README.txt"
		echo "DIR_LIB		LSB: /lib" >>"README.txt"
		echo "DIR_SBIN		LSB: /sbin		XSB: /bin" >>"README.txt"
		echo "DIR_SHARE		LSB: /usr/share		XSB: /var/share" >>"README.txt"
		echo "DIR_VAR		LSB: /var" >>"README.txt"
		echo "DIR_MARKERS	LSB: -			XSB: /var/cache/software" >>"README.txt"
		echo "DIR_SCRIPTS	LSB: /etc/init.d" >>"README.txt"
		echo >>"README.txt"
		echo "Compile 'configure' Directory Locations:" >>"README.txt"
		echo "CFG_BIN		LSB: DIR_INST/bin" >>"README.txt"
		echo "CFG_DATA		LSB: DIR_INST/share	XSB: DIR_INST/var/share" >>"README.txt"
		echo "CFG_DATAROOT	LSB: CFG_DATA" >>"README.txt"
		echo "CFG_DOC		LSB: CFG_DATA/doc/NAME" >>"README.txt"
		echo "CFG_DVI		LSB: CFG_DOC" >>"README.txt"
		echo "CFG_HTML		LSB: CFG_DOC" >>"README.txt"
		echo "CFG_INCLUDE	LSB: DIR_INST/include	XSB: DIR_INST/lib/include" >>"README.txt"
		echo "CFG_INFO		LSB: CFG_DATA/info" >>"README.txt"
		echo "CFG_LIB		LSB: DIR_INST/lib" >>"README.txt"
		echo "CFG_LIBEXEC	LSB: DIR_INST/libexec	XSB: CFG_LIB/exec" >>"README.txt"
		echo "CFG_LOCALE	LSB: CFG_DATA/locale" >>"README.txt"
		echo "CFG_LOCALSTATE	LSB: DIR_INST/var" >>"README.txt"
		echo "CFG_MAN		LSB: CFG_DATA/man" >>"README.txt"
		echo "CFG_OLDINCLUDE	LSB: /usr/local/include	XSB: DIR_INST/lib/include" >>"README.txt"
		echo "CFG_PDF		LSB: CFG_DOC" >>"README.txt"
		echo "CFG_PS		LSB: CFG_DOC" >>"README.txt"
		echo "CFG_SBIN		LSB: DIR_INST/sbin	XSB: DIR_INST/bin" >>"README.txt"
		echo "CFG_SHAREDSTATE	LSB: DIR_INST/com	XSB: DIR_INST/var" >>"README.txt"
		echo "CFG_SYSCONFIG	LSB: DIR_INST/etc" >>"README.txt"
		echo "CFG_MISC		" >>"README.txt"
		echo >>"README.txt"
		echo "The CFG_MISC is a builder extra variable that can be used per project, but will" >>"README.txt"
		echo "need its associated switch. So, for example, mplayer has a non-standard switch" >>"README.txt"
		echo "to place its codecs. Simply enter \"--codec-dir='/whatever/dir'\" for this" >>"README.txt"
		echo "variable value to use it." >>"README.txt"

		cd ..
		echo "The presence of this file indicates that a final cleanup" >proper
		echo "call will be initiated. If this is undesired, then delete" >>proper
		echo "this file." >>proper

		echo "# Specify any default parameter values using this file." >params
		echo "# These can be overwritten via passed values. This file" >>params
		echo "# can also be deleted to accept default values." >>params
		echo >>params
		echo "#ARCH='i64'" >params
		echo "#DIRS=''" >>params
		echo "#INFOFILE=''" >>params
		echo "#PASS=''" >>params
		echo "#SKIP='TRUE'" >>params
		echo "#TRIM=''" >>params
		echo "#METHOD='default'" >>params
		echo "#SOURCE=''" >>params

		echo "#!/bin/sh" >pre.compile
		echo "# Specify any pre-compile actions in this script. If there" >>pre.compile
		echo "# aren't any, then this file can be deleted." >>pre.compile
		echo >>pre.compile
		chmod 775 pre.compile

		echo "#!/bin/sh" >post.compile
		echo "# Specify any post-compile actions in this script. If there" >>post.compile
		echo "# aren't any, then this file can be deleted." >>post.compile
		echo >>post.compile
		chmod 775 post.compile

		echo "#!/bin/sh" >post.configure
		echo "# Specify any post-configure actions in this script. If there" >>post.configure
		echo "# aren't any, then this file can be deleted." >>post.configure
		echo >>post.configure
		chmod 775 post.configure

		echo "#!/bin/sh" >pre.package
		echo "# Specify any pre-package actions in this script. If there" >>pre.package
		echo "# aren't any, then this file can be deleted." >>pre.package
		echo >>pre.package
		chmod 775 pre.package

		echo "#!/bin/sh" >post.package
		echo "# Specify any post-package actions in this script. If there" >>post.package
		echo "# aren't any, then this file can be deleted." >>post.package
		echo >>post.package
		chmod 775 post.package

		echo "#!/bin/sh" >cleanup
		echo "# Specify any final actions before the termination of this" >>cleanup
		echo "# script. If there aren't any, then this file can be deleted." >>cleanup
		echo >>cleanup
		chmod 775 cleanup

		echo "# Toggle the execution for any of these commands" >config
		echo "# NOTE: when using multi-pass files (e.g. config.1, config.2), these can be used" >>config
		echo "#       to define which pass any of these commands are executed depending on the" >>config
		echo "#       value assigned in each config file" >>config
		echo "CHECK=0		# make check" >>config
		echo "CLEAN=1		# make clean; NOTE: a '2' value performs a 'make distclean'" >>config
		echo "CONF=1		# configure" >>config
		echo "PROP=0		# make mrproper" >>config
		echo "TEST=0		# make test" >>config
		echo "SORT=TRUE	# indicates the package contents need sorting (on this pass)" >>config
		echo "# The below variable is optional and should only be used when compiling more" >>config
		echo "# than one software with a single builder profile. For example you can compile" >>config
		echo "# both alsa-libs and alsa-utils with a single 'builder alsa' command if the" >>config
		echo "# config.1 CODE value is 'alsa-libs' and config.2 CODE value is 'alsa-utils'." >>config
		echo "# This value would uniquely identify which source code directory to use per pass" >>config
		echo "CODE=''" >>config
		echo >>config
		echo "# The URL to the developers source code located in a git repo" >>config
		echo "# NOTES:" >>config
		echo "#     - if doing multi-pass, this needs to be in the first config file" >>config
		echo "#     - this is optional but does allow a '-C git|dev' call" >>config
		echo "GIT_REPO=''" >>config
		echo "# Same as above, but the URL to a non-git (homepage) download link" >>config
		echo "URL_CODE=''" >>config
		echo >>config
		echo "# If the compile type is 'custom', you need to specify all commands here" >>config
		echo "# For example: gcc -O foo" >>config
		echo "# NOTE: if this contains variables, still surround it with single quotes!!!" >>config
		echo "CUSTOM=''" >>config
		echo >>config
		echo "# The directory where the package contents will reside in the running system" >>config
		echo "#DIR_INST='/usr/local'" >>config
		echo >>config
		echo "# Uncomment any of the directory installation locations you wish to modify" >>config
		echo "#DIR_BIN=\"\${DIR_INST}/bin\"" >>config
		echo "#DIR_ETC=\"\${DIR_INST}/etc\"" >>config
		echo "#DIR_LIB=\"\${DIR_INST}/lib\"" >>config
		echo "#DIR_SBIN=\"\${DIR_INST}/sbin\"" >>config
		echo "#DIR_SHARE=\"\${DIR_INST}/share\"" >>config
		echo "#DIR_VAR=\"\${DIR_INST}/var\"" >>config
		echo "#DIR_MARKERS=\"\${DIR_INST}/usr/local/installed\"" >>config
		echo "#DIR_SCRIPTS=\"\${DIR_INST}/etc/init.d\"" >>config
		echo >>config
		echo "# Uncomment any of the directory configuration locations you wish to modify" >>config
		echo "#CFG_BIN=\"\${DIR_INST}/bin\"" >>config
		echo "#CFG_DATA=\"\${DIR_INST}/share\"" >>config
		echo "#CFG_DATAROOT=\"\${CFG_DATA}\"" >>config
		echo "#CFG_DOC=\"\${CFG_DATA}/doc/NAME\"" >>config
		echo "#CFG_DVI=\"\${CFG_DOC}\"" >>config
		echo "#CFG_HTML=\"\${CFG_DOC}\"" >>config
		echo "#CFG_INCLUDE=\"\${DIR_INST}/include\"" >>config
		echo "#CFG_INFO=\"\${CFG_DATA}/info\"" >>config
		echo "#CFG_LIB=\"\${DIR_INST}/lib\"" >>config
		echo "#CFG_LIBEXEC=\"\${DIR_INST}/libexec\"" >>config
		echo "#CFG_LOCALE=\"\${CFG_DATA}/locale\"" >>config
		echo "#CFG_LOCALSTATE=\"\${DIR_INST}/var\"" >>config
		echo "#CFG_MAN=\"\${CFG_DATA}/man\"" >>config
		echo "#CFG_OLDINCLUDE=\"/usr/include\"" >>config
		echo "#CFG_PDF=\"\${CFG_DOC}\"" >>config
		echo "#CFG_PS=\"\${CFG_DOC}\"" >>config
		echo "#CFG_SBIN=\"\${DIR_INST}/sbin\"" >>config
		echo "#CFG_SHAREDSTATE=\"\${DIR_INST}/com\"" >>config
		echo "#CFG_SYSCONFIG=\"\${DIR_INST}/etc\"" >>config
		echo "# The CFG_MISC is a builder extra variable that can be used per project, but will" >>config
		echo "# need its associated switch. So, for example, mplayer has a non-standard switch" >>config
		echo "# to place its codecs. Simply enter \"--codec-dir='/whatever/dir'\" for this" >>config
		echo "# variable value to use it." >>config
		echo "#CFG_MISC=\"\"" >>config
		echo >>config
		echo "# Specify compile-time package dependency list to build this software" >>config
		echo "# (e.g. DEP_MAKE_PAK='autogen')" >>config
		echo "DEP_MAKE_PAK=''" >>config
		echo >>config
		echo "# Specify run-time package dependency list for each package type:" >>config
		echo "DEP_EXEC_BIN=''		# only binaries" >>config
		echo "DEP_EXEC_DEV=''		# ony development files (e.g. *.h headers)" >>config
		echo "DEP_EXEC_GIR=''		# only gir files" >>config
		echo "DEP_EXEC_LIB=''		# only libs" >>config
		echo >>config
		echo "FLAG_CONF=\"--prefix=\${DIR_INST}\"		# parameters to pass to 'configure'" >>config
		echo "FLAG_INST=\"DESTDIR=\${DIR_DUMP}/\${NAME}\"		# parameters to pass to 'make install'" >>config
		echo "FLAG_MAKE=''					# parameters to pass to 'make'" >>config
		echo >>config
		echo "# If you wish to override the system defaults for this package, adjust the following:" >>config
		echo "#FLAG_A32=\"${FLAG_A32}\"			# ARM 32bit" >>config
		echo "#FLAG_A64=\"${FLAG_A64}\"			# ARM 64bit" >>config
		echo "#FLAG_I32=\"${FLAG_I32}\"			# Intel/AMD 32bit" >>config
		echo "#FLAG_I64=\"${FLAG_I64}\"			# Intel/AMD 64bit" >>config
		echo "#FLAG_M32=\"\"				# MIPS 32bit" >>config
		echo "#FLAG_M64=\"\"				# MIPS 64bit" >>config
		echo "#FLAG_P32=\"\"				# PowerPC 32bit" >>config
		echo "#FLAG_P64=\"\"				# PowerPC 64bit" >>config
		echo "#FLAG_R32=\"${FLAG_R32}\"			# RPi 32bit" >>config
		echo "#FLAG_R64=\"${FLAG_R64}\"			# RPi 64bit" >>config
		echo "#FLAG_V32=\"\"				# RISC-V 32bit" >>config
		echo "#FLAG_V64=\"\"				# RISC-V 64bit" >>config
		echo >>config
		echo "# If you wish to override the system defaults for this package, add the variables here:" >>config

		echo
		echo "The template builder profile has been successfully created! It can be found at:"
		echo "  ${DIR_TEMP}/${NAME}"
		echo
	fi
	exit 0


elif [ "$UNINSTALL" ]; then
	echo -n "Uninstalling the builder profile:" | tee -a "$LOG"

	eval "EXT_BLDR=\"$EXT_BLDR\""

	echo -n " [file]" | tee -a "$LOG"
	if [ ! -e "${DIR_PROF}/${NAME}${EXT_BLDR}" ]; then
		echo -n " [absent]" | tee -a "$LOG"
		echo -n " [ ! -e \"${DIR_PROF}/${NAME}${EXT_BLDR}\" ]" >>"$LOG"
	else
		echo -n " [exists]" | tee -a "$LOG"
		( rm "${DIR_PROF}/${NAME}${EXT_BLDR}" 2>&1 | sed 's/^r/ \[failure\]\nr/' | tee -a "$LOG" | grep -q ^'rm: ' ) && {
			eval "echo -e \"Calling: rm \\\"${DIR_PROF}/${NAME}${EXT_BLDR}\\\"\" >>\"$LOG\""
			eval "echo \"ERROR: The package builder profile deletion failed (${NAME}${EXT_BLDR}).\" >>\"$LOG\""
			stop failed
		}
	fi

	echo -n " [profile]" | tee -a "$LOG"
	if [ ! -d "${DIR_PROF}/${NAME}" ]; then							# check that the directory name does exist in the profile listings
		echo -n " [absent]" | tee -a "$LOG"
		echo -n " [ ! -d \"${DIR_PROF}/${NAME}\" ]" >>"$LOG"
	else
		echo -n " [exists]" | tee -a "$LOG"
		( rm -Rf "${DIR_PROF}/${NAME}" 2>&1 | sed 's/^r/ \[failure\]\nr/' | tee -a "$LOG" | grep -q ^'rm: ' ) && {
			eval "echo -e \"Calling: rm -Rf \\\"${DIR_PROF}/${NAME}\\\"\" >>\"$LOG\""
			eval "echo \"ERROR: The package builder profile deletion failed (${NAME}).\" >>\"$LOG\""
			stop failed
		}
	fi
	echo " [done]" | tee -a "$LOG"
	exit 0


#elif [ "$BUILD" ]; then
#	if we're building, then all the below code needs to run
fi


echo "TYPE 6 |$TYPE|"

# BEGIN THE BUILD/COMPILE PROCESS

# for optional values not configured above
if [ "$ARCH" = 'all' ]; then					# if we need to compile all architectures, then...
	for ARCH in $(echo ${CPU} | sed 's/,/ /g'); do		# call this script for all supported CPU architectures and exit
		TEMP='"$THIS" -A "$ARCH" -M "$METHOD"'
		[ "$SOURCE" != '' ] && TEMP="$TEMP -C $SOURCE"
		[ "$DIRS" ] && TEMP="$TEMP -D"
		[ "$PASS" ] && TEMP="$TEMP -N $PASS"
		[ "$PATCH" ] && TEMP="$TEMP -P"
		[ "$SKIP" ] && TEMP="$TEMP -F"
		[ "$SINGLE" ] && TEMP="$TEMP -S"
		[ "$TRIM" ] && TEMP="$TEMP -R \"$TRIM\""
		[ "$TYPE" ] && TEMP="$TEMP -T $TYPE"
		[ ! "$UNLOAD" ] && TEMP="$TEMP -U"

		eval "$TEMP \"$NAME\""
	done
	exit 0
fi




# CHECK FOR PRIOR FAILED ATTEMPTS

# if any directory exists -AND- we are doing a single pass -or- on the first pass of a multi-pass (via cli or params file) and the .pass file doesn't exist (via 'stop failed'), then...
if ( ls -1 "${DIR_TEMP}/${NAME}" | grep -q . ) || ( ls -1 "${DIR_DUMP}/${NAME}" | grep -q . ) || [ -d "${DIR_DUMP}/${NAME}.bin" ]; then
	echo -n "It appears a prior (attempted) compile has left files, cleanup? [Y/N/Q] (N): "
	read
	[ "$REPLY" = 'Q' ] || [ "$REPLY" = 'q' ] && stop					# NOTE: the script does NOT stop here if 'yes' was requested
	[ "$REPLY" = 'Y' ] || [ "$REPLY" = 'y' ] && stop proper 0				# NOTE: the script does NOT stop here if 'yes' was requested
fi




# GET/SET THE 'PASS' AND 'SUDO' VALUES				  NOTE: the DIR_TEMP value will already be (re)set by this point

# UPDATED 2026/03/31
#[ -e "${DIR_TEMP}/${NAME}.pass" ] && {				# if we are on one of the multi-passes, then...    WARNING: this has to be processed in this order -AND- do NOT test for PASS value since it does NOT get passed on subsequent calls!
#	PASS="$(cat "${DIR_TEMP}/${NAME}.pass")"
#	TEMP=${PASS%|*}						#   store the total passes required
#	PASS=${PASS#*|}						#   store the prior pass value
#	PASS=$(( PASS + 1 ))					#   increase the value by 1
#	[ $PASS -gt $TEMP ] && stop proper			#   if we have just completed the last requred pass, then cleanup and exit
#	echo "${TEMP}|${PASS}" >"${DIR_TEMP}/${NAME}.pass"	#   if we've made it here, we still have at least one pass to perform, so update the values!
#}
[ -e "${DIR_TEMP}/${NAME}.pass" ] && pass 'inc'			# if we are on one of the multi-passes, then...    WARNING: this has to be processed in this order -AND- do NOT test for PASS value since it does NOT get passed on subsequent calls!

[ "$PASS" ] && [ ! -e "${DIR_TEMP}/${NAME}.pass" ] && {		# if we need to perform multi-passes and none are recorded yet, then...
	echo "${PASS}|1" >"${DIR_TEMP}/${NAME}.pass"		#   stored value in format of: TOTAL|CURRENT
	PASS=1							#   now store the value that we are working on the first pass
}

( [ "$SUDO" = 'TRUE' ] || [ "$SUDO" = '1' ] ) && SUDO='sudo'	# update the value to be the binary name so we can use it like "$SUDO mv ..."	NOTE: to use 'sudo' with parameters, simply add them for the SUDO value in the /etc/builder/config file (e.g. SUDO='sudo -x -y -z')




# OPTIONALLY SHOW DEBUG OUTPUT

[ $DEBUG -gt 0 ] && {
	echo -e "\nConfiguration during this pass..." | tee -a "$LOG"
	echo "   ARCH: $ARCH" | tee -a "$LOG"
	echo "   DIRS: $DIRS" | tee -a "$LOG"
	echo -n "   NAME: $NAME [" | tee -a "$LOG"
	eval "echo \"${EXT_MAKE}]\" | tee -a \"$LOG\""
	echo "   PASS: $PASS" | tee -a "$LOG"
	echo "   SKIP: $SKIP" | tee -a "$LOG"
	echo "   TRIM: $TRIM" | tee -a "$LOG"
	echo "   TYPE: $TYPE" | tee -a "$LOG"
	echo "   METH: $METHOD" | tee -a "$LOG"
	echo "   SRCE: $SOURCE" | tee -a "$LOG"
	echo | tee -a "$LOG"
	echo "   CHECK: $CHECK" | tee -a "$LOG"
	echo "   CLEAN: $CLEAN" | tee -a "$LOG"
	echo "   CONF: $CONF" | tee -a "$LOG"
	echo "   PROP: $PROP" | tee -a "$LOG"
	echo "   SORT: $SORT" | tee -a "$LOG"
	echo "   TEST: $TEST" | tee -a "$LOG"
	echo "   CODE: $CODE" | tee -a "$LOG"
	echo | tee -a "$LOG"
	echo "   FLAG_CONF: $FLAG_CONF" | tee -a "$LOG"
	echo "   FLAG_INST: $FLAG_INST" | tee -a "$LOG"
	echo "   FLAG_MAKE: $FLAG_MAKE" | tee -a "$LOG"
	echo | tee -a "$LOG"
	echo "   DIR_DUMP: $DIR_DUMP" | tee -a "$LOG"
	echo "   DIR_INST: $DIR_INST" | tee -a "$LOG"
	echo "   DIR_PROF: $DIR_PROF" | tee -a "$LOG"
	echo "   DIR_REPO: $DIR_REPO" | tee -a "$LOG"
	echo "   DIR_TEMP: $DIR_TEMP" | tee -a "$LOG"
	echo | tee -a "$LOG"
	echo -n "   URL_CODE: " | tee -a "$LOG"
	eval "echo \"$URL_CODE\" | tee -a \"$LOG\""
	echo -n "   URL_REPO: " | tee -a "$LOG"
	eval "echo \"$URL_REPO\" | tee -a \"$LOG\""
	echo -n "   URL_INFO: " | tee -a "$LOG"
	eval "echo \"$URL_INFO\" | tee -a \"$LOG\""
	echo | tee -a "$LOG"
	echo "   EXPORTS:" | tee -a "$LOG"
	echo "$EXPORTS" | sed 's/^[ \t]*/   /' | tee -a "$LOG"
}




# FETCH COMPILE-TIME DEPENDENCIES

echo -e "\nInstalling compile-time dependencies..." | tee -a "$LOG"

# for core software by builder itself
[ "$DEP_MAKE_ALL" ] && ( [ ! "$PASS" ] || [ $PASS -eq 1 ] ) && { eval "$SPM_ALL 2>>\"$LOG\"" || stop clean; }					# if we are only doing a single pass -OR- are on the first pass, then...

# for the software project itself
[ "$DEP_MAKE_PAK" ] && { eval "$SPM_PACK 2>>\"$LOG\"" || stop clean; }




# FETCH SOURCE CODE

if [ "$SOURCE" ]; then										# if we need to obtain the source code before we start, then...
	echo "Calling: cd \"${DIR_TEMP}/${NAME}\"" >>"$LOG"
	cd "${DIR_TEMP}/${NAME}" || {
		echo "ERROR: The temp directory could not be entered." >>"$LOG"
		stop failed
	}

	if [ "$INFOFILE" ]; then
		echo -e "\nObtaining information..." | tee -a "$LOG"

		OARCH="$ARCH"									# temporarily store the old value
		ARCH='all'
		[ "$TRIM" ] && TEMP="$(echo "$NAME" | sed "s/${TRIM}//")"			# apply package name trimming beforehand
		[ ! "$TRIM" ] && TEMP="$NAME"
		TEMP="$(echo "$URL_INFO" | sed "s/\${NAME}/$TEMP/g")"				# make name substitution in the URL (e.g. liba52 > a52)
		eval "TEMP=\"$TEMP\""								# eval the TEMP value to fill any variables
		if [ -e "$(echo ${TEMP##*/})" ]; then						# if the .info file is already downloaded (to prevent an error below), then...
			TEMP="$(echo ${TEMP##*/})"						#   store that filename
		else										# otherwise
			echo "Calling: wget -cq \"$TEMP\"" >>"$LOG"
			wget -cq "$TEMP" 2>>"$LOG" || stop failed				#   download the proper .info file to get the download location and filename
			TEMP="${TEMP##*/}"							#   store the filename that was just downloaded
		fi
		ARCH="$OARCH"									# restore the prior value
		unset $OARCH									# get rid of that variable

		# now set the variable values for the below code blocks
		if [ "$SOURCE" = 'dev' ]; then
			if ( grep -e ^'download:' "${TEMP}" | sed -r 's/^.*:[\t]+//' | grep -qE ^'(ht|f)tp' ); then				# if the 'download' value is not a continuation of the 'homepage', then it's the entire URL so...
				URL_CODE="$(grep -e ^'download:' "${TEMP}" | sed -r 's/^.*:[\t]+//')"
			elif [ "$(grep -e ^'download:' "${TEMP}" | sed -r 's/^.*:[\t]*//')" ]; then						# otherwise it is has a value and is a continuation, then append it to 'homepage'...
				URL_CODE="$(grep -i -e ^'homepage:' -e ^'download:' "${TEMP}" | sed -r 's/^.*:[\t]+//' | tr '\n' '/' | sed 's:/$::')"
			fi
			[ ! "$URL_CODE" ] && { echo -e "ERROR: The info file does not contain a valid source code download value\n       for this location." && stop failed; }
		elif [ "$SOURCE" = 'git' ]; then
			# if there's a 'file' value, then...
			[ "$(grep -e ^'file:' "${TEMP}" | sed -r 's/^.*:[\t]*//')" ] && GIT_REPO="$(grep -i -e ^'git:' -e ^'file:' "${TEMP}" | sed -r 's/^.*:[\t]+//' | tr '\n' '/' | sed 's:/$::')"
			# NOTE: we do NOT check if 'clone:' has a value since it may not
			[ ! "$GIT_REPO" ] && GIT_REPO="$(grep -i -e ^'git:' -e ^'clone:' "${TEMP}" | sed -r 's/^.*:[\t]+//' | tr '\n' '/' | sed 's:/$::')"
			[ ! "$GIT_REPO" ] && { echo -e "ERROR: The info file does not contain a valid source code download value\n       for this location." && stop failed; }
		elif [ "$SOURCE" = 'repo' ]; then
			# if there's a 'source' value, then...
			[ "$(grep -e ^'source:' "${TEMP}" | sed -r 's/^.*:[\t]*//')" ] && URL_REPO="$(grep -i -e ^'repo:' -e ^'source:' "${TEMP}" | sed -r 's/^.*:[\t]+//' | tr '\n' '/' | sed 's:/$::')"
			[ ! "$URL_REPO" ] && { echo -e "ERROR: The info file does not contain a valid source code download value\n       for this location." && stop failed; }
		fi
	fi

	echo -e "\nObtaining source code..." | tee -a "$LOG"

	eval "EXT_CODE=\"$EXT_CODE\""

	[ "$TRIM" ] && TEMP="$(echo "$NAME" | sed "s/${TRIM}//")"				# apply the trim beforehand
	[ ! "$TRIM" ] && TEMP="$NAME"

	if ( [ "$SOURCE" != 'git' ] && [ -e "$(eval "echo ${TEMP}${EXT_CODE}")" ] ) || ( [ "$SOURCE" = 'git' ] && [ -e ".git" ] ); then		# if the source code is already present, then...
		echo "ERROR: The source code is already present and needs to be moved or deleted."
		stop failed
	fi											# otherwise lets get it!

	[ "$SOURCE" = 'dir' ] && {
		echo "Calling: cp \"${DIRECTORY}\" ./" >>"$LOG"
		cp "${DIRECTORY}" ./ 2>>"$LOG" || stop failed
	}
	[ "$SOURCE" = 'dev' ] && {
		TEMP="$(echo "$URL_CODE" | sed "s/\${NAME}/${TEMP}/g")"
		eval "echo \"Calling: wget -cq \\\"$TEMP\\\"\" >>\"$LOG\""
		eval "wget -cq \"$TEMP\" 2>>\"$LOG\"" || stop failed
	}
	[ "$SOURCE" = 'git' ] && {
		if ( echo "$GIT_REPO" | grep -qE '(tgz|zip)'$ ); then				# if the git link is a distributable file, then...
			eval "echo \"Calling: wget -cq \\\"$GIT_REPO\\\"\" >>\"$LOG\""
			eval "wget -cq \"$GIT_REPO\" 2>>\"$LOG\"" || stop failed		#   download it
			SOURCE='git2'								#   temporarily change the value so the below uncompression code can run
		else										# otherwise, we have a git repo to clone, so...
			TEMP="$(echo "$GIT_REPO" | sed "s/\${NAME}/$TEMP/g")"
			eval "echo \"Calling: git clone \\\"$TEMP\\\"\" >>\"$LOG\""
			eval "git clone \"$TEMP\" 2>>\"$LOG\"" || stop failed			#   clone it!
		fi
	}
	[ "$SOURCE" = 'repo' ] && {
		TEMP="$(echo "${URL_REPO}" | sed "s/\${NAME}/$TEMP/g")"
		( echo "$TEMP" | grep -q "${NAME}${EXT_CODE}"$ ) || TEMP="${TEMP}/${NAME}${EXT_CODE}"						# if the URL_REPO was not assigned via -I above, then we need to append the filename to the URL
		eval "echo \"Calling: wget -cq \\\"${TEMP}\\\"\" >>\"$LOG\""
		( eval "wget -cq \"${TEMP}\" 2>>\"$LOG\"" ) || stop failed
	}

	if [ "$SOURCE" != 'git' ]; then								# if we're not cloing a git repo (since it would already be uncompressed files), then...
		TEMP="$(ls -1t | head -1)"							#    store the filename that was just downloaded
		echo "Source Code File: $TEMP" >>"$LOG"
		case $(file -b --mime-type "$TEMP") in
			'application/zip') unzip "$TEMP" 2>>"$LOG" ;;
			'application/gzip'|'application/x-gzip') tar -xzf "$TEMP" 2>>"$LOG" ;;
			'application/bzip2'|'application/x-bzip2')
				[ ! -e "${TEMP%.*}" ] && bunzip2 "$TEMP" 2>>"$LOG"		#    if the file is already uncompressed, then do so now
				tar -xf "${TEMP%.*}" 2>>"$LOG"
				;;
		esac
		[ "$SOURCE" = 'git2' ] && SOURCE='git'						#    if the value had been temporarily changed above, we now need to change it back
	fi

	echo -e "Detected:\n$(ls -tdpr -- * | grep '/'$)" >>"$LOG"
	echo "Calling: cd \"$(ls -tdpr -- * | grep '/'$ | head -1)\"" >>"$LOG"
	cd "$(ls -tdpr -- * | grep '/'$ | head -1)" 2>>"$LOG" || {				# change into the (unknown named) directory created by the copy/clone/uncompression above (source code directory)	https://unix.stackexchange.com/questions/136976/get-the-latest-directory-not-the-latest-file
		echo "ERROR: The source code directory could not be entered." >>"$LOG"
		stop failed
	}

elif [ "$CODE" ]; then										# if we have a CODE value, then we need to change into that directory before we continue!
	echo -e "\nEntering source code directory..." | tee -a "$LOG"

	echo -e "Detected:\n$(ls -1dp -- * | grep ^"$CODE" | grep '/'$ | head -1)" >>"$LOG"
	TEMP="$(ls -1dp -- * | grep ^"$CODE" | grep '/'$ | head -1)"
	[ ! "$TEMP" ] && {
		echo "ERROR: The source code directory could not be found." >>"$LOG"
		stop failed
	}
	echo "Calling: cd \"$TEMP\"" >>"$LOG"
	cd "$TEMP" 2>>"$LOG" || {								# change into the directory that matches the unique CODE value
		echo "ERROR: The source code directory could not be entered." >>"$LOG"
		stop failed
	}
fi

# NOTE: we are now in the correct directory to perform all the following actions

if [ "$METHOD" = 'autoconf' ] && [ ! -e 'configure.ac' ]; then
	echo "ERROR: It does not appear that builder was called from within the source code directory." >>"$LOG"
	stop failed
elif [ "$METHOD" = 'autogen' ] && [ ! -e 'autogen.sh' ]; then
	echo "ERROR: It does not appear that builder was called from within the source code directory." >>"$LOG"
	stop failed
elif [ "$METHOD" = 'bootstrap' ] && [ ! -e 'CMakeLists.txt' ]; then				# this is just a wrapper for the 'cmake' build system
	echo "ERROR: It does not appear that builder was called from within the source code directory." >>"$LOG"
	stop failed
elif [ "$METHOD" = 'cmake' ] && [ ! -e 'CMakeLists.txt' ]; then
	echo "ERROR: It does not appear that builder was called from within the source code directory." >>"$LOG"
	stop failed
elif [ "$METHOD" = 'default' ] && [ ! -e 'configure' ] && [ ! -e 'Makefile' ]; then
	echo "ERROR: It does not appear that builder was called from within the source code directory." >>"$LOG"
	stop failed
elif [ "$METHOD" = 'scons' ] && [ ! -e 'SConstruct' ]; then
	echo "ERROR: It does not appear that builder was called from within the source code directory." >>"$LOG"
	stop failed
fi




# APPLY ANY PATCHES

if [ "$PATCH" ]; then
	echo -e "\nApplying software patches..." | tee -a "$LOG"

	OLDIFS="$IFS"
	if [ ! "$PASS" ]; then					# if we are not doing multi-pass, or we are on the first pass of a multi-pass, then...
		IFS=$'\n'
		for PATCH in $(ls -1 "${DIR_PROF}/${NAME}/patches" 2>/dev/null); do
			[ ! "$PATCH" ] && continue		# no clue why this is even having to be processed, but...

			echo -n "   ${PATCH##*/}: " | tee -a "$LOG"
			if [ -x "${DIR_PROF}/${NAME}/patches/${PATCH}" ]; then
				"${DIR_PROF}/${NAME}/patches/${PATCH}" || {
					echo "[failure]"
					echo "      [failure]" >>"$LOG"
					stop failed
				}
			else
				patch -p 0 < "${DIR_PROF}/${NAME}/patches/${PATCH}" >/dev/null 2>>"$LOG" || {
					echo "[failure]"
					echo "      [failure]" >>"$LOG"
					stop failed
				}
			fi
			echo "[success]" | tee -a "$LOG"
		done 2>/dev/null
	else
		IFS=$'\n'
		for PATCH in $(ls -1 "${DIR_PROF}/${NAME}/patches.${PASS}" 2>/dev/null); do
			[ ! "$PATCH" ] && continue		# no clue why this is even having to be processed, but...

			echo -n "   ${PATCH##*/}: " | tee -a "$LOG"
			if [ -x "${DIR_PROF}/${NAME}/patches.${PASS}/${PATCH}" ]; then
				"${DIR_PROF}/${NAME}/patches.${PASS}/${PATCH}" || {
					echo "[failure]"
					echo "      [failure]" >>"$LOG"
					stop failed
				}
			else
				patch -p 0 < "${DIR_PROF}/${NAME}/patches.${PASS}/${PATCH}" >/dev/null 2>>"$LOG" || {
					echo "[failure]"
					echo "      [failure]" >>"$LOG"
					stop failed
				}
			fi
			echo "[success]" | tee -a "$LOG"
		done 2>/dev/null
	fi
	IFS="$OLDIFS"
	unset OLDIFS
fi




# PERFORM THE ACTUAL COMPILE

[ ! "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/pre.compile" ] && {					# execute any existing pre-compile script (for single-pass; multi-pass is next block)
	echo -e "\nExecuting the 'pre.compile' script..." | tee -a "$LOG"
	"${DIR_PROF}/${NAME}/pre.compile" 2>>"$LOG" || stop failed
}
[ "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/pre.compile.${PASS}" ] && {
	echo -e "\nExecuting the 'pre.compile' script..." | tee -a "$LOG"
	"${DIR_PROF}/${NAME}/pre.compile.${PASS}" 2>>"$LOG" || stop failed
}

eval "EXT_MAKE=\"$EXT_MAKE\""

echo -e "\nGenerating the compile script..." | tee -a "$LOG"
echo "#!/bin/sh" >"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset DIR_CONF DIR_DUMP DIR_INST DIR_PROF DIR_REPO DIR_TEMP' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"						# unset these variables set at the top of this script to not pollute the compile environment
echo 'unset DIR_BIN DIR_ETC DIR_LIB DIR_SBIN DIR_SHARE DIR_VAR DIR_MARKERS DIR_SCRIPTS' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset DEP_MAKE_ALL' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset EXT_BLDR EXT_CODE EXT_DEPS EXT_HASH EXT_INFO EXT_LIST EXT_MAKE EXT_SOFT' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset OWN_USER OWN_GROUP' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset PRM_DIRS PRM_FILES PRM_EXECS' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset URL_CODE URL_REPO URL_INFO' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset SPM_ALL SPM_PACK SPM_UNLD' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset CPU SUDO' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo 'unset DEBUG' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo "$EXPORTS" | sed 's/^[ \t]*//' >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
echo >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
[ $CLEAN -eq 2 ] && { echo "make distclean >>\"$LOG\" 2>&1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }
[ $CLEAN -eq 1 ] && { echo "make clean >>\"$LOG\" 2>&1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }
[ $PROP -eq 1 ] && { echo "make mrproper >>\"$LOG\" 2>&1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }

TEMP=''
for DIR in CFG_BIN CFG_DATA CFG_DATAROOT CFG_DOC CFG_DVI CFG_HTML CFG_INCLUDE CFG_INFO CFG_LIB CFG_LIBEXEC CFG_LOCALE CFG_LOCALSTATE CFG_MAN CFG_OLDINCLUDE CFG_PDF CFG_PS CFG_SBIN CFG_SHAREDSTATE CFG_SYSCONFIG CFG_MISC; do
	[ "$(eval "echo \$$DIR")" = '' ] && continue
	case $DIR in
		CFG_BIN) eval "TEMP=\"$TEMP --bindir='\$$DIR'\"" ;;
		CFG_DATA) eval "TEMP=\"$TEMP --datadir='\$$DIR'\"" ;;
		CFG_DATAROOT) eval "TEMP=\"$TEMP --datarootdir='\$$DIR'\"" ;;
		CFG_DOC) eval "TEMP=\"$TEMP --docdir='\$$DIR'\"" ;;
		CFG_DVI) eval "TEMP=\"$TEMP --dvidir='\$$DIR'\"" ;;
		CFG_HTML) eval "TEMP=\"$TEMP --htmldir='\$$DIR'\"" ;;
		CFG_INCLUDE) eval "TEMP=\"$TEMP --includedir='\$$DIR'\"" ;;
		CFG_INFO) eval "TEMP=\"$TEMP --infodir='\$$DIR'\"" ;;
		CFG_LIB) eval "TEMP=\"$TEMP --libdir='\$$DIR'\"" ;;
		CFG_LIBEXEC) eval "TEMP=\"$TEMP --libexecdir='\$$DIR'\"" ;;
		CFG_LOCALE) eval "TEMP=\"$TEMP --localedir='\$$DIR'\"" ;;
		CFG_LOCALSTATE) eval "TEMP=\"$TEMP --localstatedir='\$$DIR'\"" ;;
		CFG_MAN) eval "TEMP=\"$TEMP --mandir='\$$DIR'\"" ;;
		CFG_OLDINCLUDE) eval "TEMP=\"$TEMP --oldincludedir='\$$DIR'\"" ;;
		CFG_PDF) eval "TEMP=\"$TEMP --pdfdir='\$$DIR'\"" ;;
		CFG_PS) eval "TEMP=\"$TEMP --psdir='\$$DIR'\"" ;;
		CFG_SBIN) eval "TEMP=\"$TEMP --sbindir='\$$DIR'\"" ;;
		CFG_SHAREDSTATE) eval "TEMP=\"$TEMP --sharedstatedir='\$$DIR'\"" ;;
		CFG_SYSCONFIG) eval "TEMP=\"$TEMP --sysconfdir='\$$DIR'\"" ;;
		CFG_MISC) eval "TEMP=\"$TEMP \$$DIR\"" ;;
	esac
done

if [ "$METHOD" = 'autoconf' ]; then
	echo "autoreconf -fi >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	[ $CONF -eq 1 ] && { echo "./configure$TEMP $FLAG_CONF >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }
elif [ "$METHOD" = 'autogen' ]; then
	echo "./autogen.sh >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	[ $CONF -eq 1 ] && { echo "./configure$TEMP $FLAG_CONF >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }
elif [ "$METHOD" = 'bootstrap' ]; then
	[ -e bootstrap ] && echo "./bootstrap >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	[ -e bootstrap.sh ] && echo "./bootstrap.sh >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	[ $CONF -eq 1 ] && { echo "./configure$TEMP $FLAG_CONF >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }
elif [ "$METHOD" = 'cmake' ]; then
	echo "mkdir build_me >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "cd build_me >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "cmake $FLAG_CONF .. >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
elif [ "$METHOD" = 'custom' ]; then
	eval "echo \"$CUSTOM >>\\\"$LOG\\\" 2>&1 || exit 1\" >>\"${DIR_TEMP}/${NAME}${EXT_MAKE}\""
elif [ "$METHOD" = 'default' ]; then
	[ $CONF -eq 1 ] && { echo "./configure$TEMP $FLAG_CONF >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"; }
elif [ "$METHOD" = 'scons' ]; then
	echo "scons $FLAG_CONF >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
fi

[ ! "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/post.configure" ] && {										# execute any existing post-configure script (for single-pass; multi-pass is next block)
	echo "echo -e \"   Executing the 'post.configure' script...\" | tee -a \"$LOG\"" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "${DIR_PROF}/${NAME}/post.configure >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "echo -e \"   Proceeding with next steps of compile...\" | tee -a \"$LOG\"" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
}
[ "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/post.configure.${PASS}" ] && {
	echo "echo -e \"   Executing the 'post.configure' script...\" | tee -a \"$LOG\"" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "${DIR_PROF}/${NAME}/post.configure.${PASS} >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "echo -e \"   Proceeding with next steps of compile...\" | tee -a \"$LOG\"" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
}

if [ "$METHOD" != 'scons' ]; then
	echo "make $FLAG_MAKE >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"							# NOTE: 'nice' should help prevent non-responding system crashes, and '-j' indicates to use all cores of a CPU during compiling
	[ $CHECK -eq 1 ] && echo "make check >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	[ $TEST -eq 1 ] && echo "make test >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
	echo "make install $FLAG_INST >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"						# install the newly compiled software in the temp packaging directory
elif [ "$METHOD" = 'scons' ]; then
	echo "scons install $FLAG_INST >>\"$LOG\" 2>&1 || exit 1" >>"${DIR_TEMP}/${NAME}${EXT_MAKE}"
fi
chmod 775 "${DIR_TEMP}/${NAME}${EXT_MAKE}"

echo -e "\nCompiling the software..." | tee -a "$LOG"
"${DIR_TEMP}/${NAME}${EXT_MAKE}" || stop failed

echo -e "\nCopying in the 'include' files..." | tee -a "$LOG"
TEMP=''
for DIR in DIR_BIN DIR_ETC DIR_LIB DIR_SBIN DIR_SHARE DIR_VAR DIR_MARKERS DIR_SCRIPTS CFG_BIN CFG_DATA CFG_DATAROOT CFG_DOC CFG_DVI CFG_HTML CFG_INCLUDE CFG_INFO CFG_LIB CFG_LIBEXEC CFG_LOCALE CFG_LOCALSTATE CFG_MAN CFG_OLDINCLUDE CFG_PDF CFG_PS CFG_SBIN CFG_SHAREDSTATE CFG_SYSCONFIG CFG_MISC; do
	# skip the processing of the directory if either of these two conditions are met
	( [ "$(eval "echo \$$DIR")" = '' ] || [ "$DIR" = 'CFG_MISC' ] ) && continue
	[ ! -e "${DIR_PROF}/${NAME}/include/${DIR}" ] && [ ! -e "${DIR_PROF}/${NAME}/include.${PASS}/${DIR}" ] && continue

	mkdir -p "${DIR_DUMP}/${NAME}/$(eval "echo \$$DIR")" 2>>"$LOG"
	[ "$PASS" ] && cp -dpR "${DIR_PROF}/${NAME}/include.${PASS}/${DIR}/"* "${DIR_DUMP}/${NAME}/$(eval "echo \$$DIR")" 2>>"$LOG"
	[ ! "$PASS" ] && cp -dpR "${DIR_PROF}/${NAME}/include/${DIR}/"* "${DIR_DUMP}/${NAME}/$(eval "echo \$$DIR")" 2>>"$LOG"
done

[ ! "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/post.compile" ] && {											# execute any existing post-compile script (for single-pass; multi-pass is next line)
	echo -e "\nExecuting the 'post.compile' script..." | tee -a "$LOG"
	"${DIR_PROF}/${NAME}/post.compile" 2>>"$LOG" || stop failed
}
[ "$PASS" ] && [ -x "${DIR_PROF}/${NAME}/post.compile.${PASS}" ] && {
	echo -e "\nExecuting the 'post.compile' script..." | tee -a "$LOG"
	"${DIR_PROF}/${NAME}/post.compile.${PASS}" 2>>"$LOG" || stop failed
}




# INSTALL TO SYSTEM IF COMPILE ONLY





# OPTIONALLY PACKAGE or INSTALL SOFTWARE

if [ "$BUILD" = 'package' ]; then								# if we are packaging, then call those routines
	package

elif [ "$BUILD" = 'install' ] && ( [ ! "$PASS" ] || [ $PASS -eq $(cat "${DIR_TEMP}/${NAME}.pass" | sed 's/|.*//') ] ); then			# otherwise we are doing a compile-only and need to install (if this is the only/last pass)
	# NOTE: this is a separate step since builder ALWAYS installs to the
	# staging directory so 'include' files can be added before installation

	echo -e "\nInstalling the compiled software..." | tee -a "$LOG"

	echo "Calling: cd \"${DIR_DUMP}/${NAME}\"" >>"$LOG"
	cd "${DIR_DUMP}/${NAME}" 2>>"$LOG" || {							# change into the temp packaging directory
		echo "ERROR: The staging location directory (DIR_DUMP) could not be entered." >>"$LOG"
		stop failed
	}
	echo "Calling: $SUDO cp -dpR ./* /" >>"$LOG"
	eval "$SUDO cp -dpR ./* / 2>>\"$LOG\"" || {						# now copy the contents to the root of the file system
		echo "ERROR: The compiled software could not be installed." >>"$LOG"
		stop failed
	}
fi




# COMPILATION CLEANUP

if [ "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/proper.${PASS}" ]; then				# if doing multi-pass -AND- automatic cleanup is requested on this pass...
	echo -e "\nCleaning the source code directory..." | tee -a "$LOG"

	if [ $PASS -eq $(cat "${DIR_TEMP}/${NAME}.pass" | sed 's/|.*//') ]; then		# if we are on the last pass, then...
		PASS=''										#   update the value so the next section won't be triggered (since its tracker file will be deleted below!)
		stop proper 0									#   cleanup whole environment
	else											# otherwise we are on one of the passes, so...
		stop clean 0									#   perform a partial cleanup
	fi
elif [ ! "$PASS" ] && [ -e "${DIR_PROF}/${NAME}/proper" ]; then					# if only doing a single pass -AND- automatic cleanup is requested...
	echo -e "\nCleaning the source code directory..." | tee -a "$LOG"

	stop proper 0
elif [ ! "$PASS" ] || [ $PASS -eq $(cat "${DIR_TEMP}/${NAME}.pass" | sed 's/|.*//') ]; then	# if only doing a single pass -OR- we are on the last pass, then...
	echo -en "\nWould you like to cleanup now that the software has been processed? [Y/N] (N): "
	read
	[ "$REPLY" = 'Y' ] || [ "$REPLY" = 'y' ] && stop proper 0

	[ "$PASS" ] && PASS=''									# if we are on the last pass, update the value so the next section won't be triggered (since its tracker file just got deleted!)
fi




# OPTIONAL MULTI-PASS CALL

[ "$PASS" ] && {
	echo -e "\nStarting the next pass..." | tee -a "$LOG"
# passed D P F T lib U alsa
# LEFT OFF - if any of these are in the 'params' or 'params.*' files, then do NOT include them below!
	TEMP='"$THIS" -A "$ARCH" -M "$METHOD"'
	[ "$SOURCE" != '' ] && TEMP="$TEMP -C $SOURCE"
	[ "$DIRS" ] && TEMP="$TEMP -D"
	#[ "$PASS" ] && TEMP="$TEMP -N $PASS"							  NOTE: we do NOT pass this value here since it will be picked up automatically at the top of the script
	[ "$PATCH" ] && TEMP="$TEMP -P"
	[ "$SKIP" ] && TEMP="$TEMP -F"
	[ "$SINGLE" ] && TEMP="$TEMP -S"
	[ "$TRIM" ] && TEMP="$TEMP -R \"$TRIM\""
	[ "$TYPE" ] && TEMP="$TEMP -T $TYPE"
	[ ! "$UNLOAD" ] && TEMP="$TEMP -U"

	cd "$CWDL"

	eval "$TEMP \"$NAME\""
	exit 0
}

[ "$BUILD" = 'install' ] && echo -e "\nCongrats, the software has been compiled successfully!\n" | tee -a "$LOG"
[ "$BUILD" = 'package' ] && echo -e "\nCongrats, the software has been packaged successfully!\n" | tee -a "$LOG"

